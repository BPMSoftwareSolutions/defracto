      "inputSchemaPath": "contracts/schemas/command-invocation-receipt.schema.v1.json",
      "signaturePolicyPath": "conveyor/trust/surface-signature.policy.v1.json"
    },
    {
      "command": "ndd handoff run --text <operatorText> --slice <sliceKey>",
