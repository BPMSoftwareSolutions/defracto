{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defracto.telemetry-status-projection.v1",
  "title": "Telemetry Status Projection",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectionKey",
    "status",
    "captures",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "defracto.telemetry-status-projection.v1"
    },
    "projectionKey": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "blocked"
      ]
    },
    "captures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
