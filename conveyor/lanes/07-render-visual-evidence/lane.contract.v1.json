{
  "schemaVersion": "defracto.conveyor-lane-contract.v1",
  "laneKey": "defracto.lanes.07-render-visual-evidence.v1",
  "laneIndex": 7,
  "laneTitle": "Render Visual Evidence",
  "laneStatus": "accepted",
  "role": "Generate or update run visual evidence from declared visual authority.",
  "inputContracts": [
    {
      "artifactKind": "runState",
      "required": true,
      "source": "prior-lane"
    },
    {
      "artifactKind": "conformanceReceipt",
      "required": true,
      "source": "prior-lane"
    },
    {
      "artifactKind": "visualProjectionModel",
      "required": true,
      "source": "prior-lane"
    }
  ],
  "outputContracts": [
    {
      "artifactKind": "visualEvidenceSurface",
      "required": true,
      "target": "conveyor/lanes/07-render-visual-evidence/outputs/visualEvidenceSurface.json"
    },
    {
      "artifactKind": "visualEvidenceReceipt",
      "required": true,
      "target": "conveyor/lanes/07-render-visual-evidence/outputs/visualEvidenceReceipt.json"
    }
  ],
  "workerRuntime": {
    "workerKey": "defracto.workers.gemini_flash.v1",
    "workerProfilePath": "conveyor/workers/gemini-flash.worker-profile.v1.json",
    "dispatchContractPath": "conveyor/workers/gemini-flash.dispatch-contract.v1.json",
    "responseContractPath": "conveyor/workers/gemini-flash.response-contract.v1.json",
    "agentRole": "visual-proof-agent",
    "liveRuntimeRequired": true,
    "failClosedIfUnavailable": true
  },
  "handoff": {
    "mode": "lane-scoped-dispatch",
    "nextLane": "08-review-evidence",
    "requiresPriorReceipt": true,
    "requiresReceiptBeforeAdvance": true,
    "dispatchShape": "defracto.conveyor-lane-dispatch.v1",
    "receiptShape": "defracto.conveyor-lane-receipt.v1"
  },
  "evidence": {
    "required": true,
    "receiptPathTemplate": "{runPath}/lanes/07-render-visual-evidence/receipt.v1.json",
    "responsePathTemplate": "{runPath}/lanes/07-render-visual-evidence/response.gemini-flash.v1.json",
    "dispatchPathTemplate": "{runPath}/lanes/07-render-visual-evidence/dispatch.gemini-flash.v1.json",
    "hashMaterializedOutputs": true,
    "surfaceSignatureRequired": true
  },
  "blockedConditions": [
    "visual authority missing",
    "conformance receipt missing",
    "manual sketch detected",
    "visual receipt missing"
  ],
  "allowedResponsibilities": [
    "visual evidence projection",
    "run sketch target",
    "visual proof receipt"
  ],
  "forbiddenResponsibilities": [
    "freehand ASCII",
    "layout invention",
    "renderer-owned truth"
  ],
  "completionPosture": "Render Visual Evidence passes only when it emits visualEvidenceSurface, visualEvidenceReceipt and a receipt before handing off to 08-review-evidence."
}
