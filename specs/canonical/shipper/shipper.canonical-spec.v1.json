{
  "schemaVersion": "defracto.canonical-spec.v1",
  "canonicalSpecKey": "defracto.shipper.canonical-spec.v1",
  "derivedFromStory": "defracto.shipper.story.v1",
  "purpose": "Define the authoritative role, boundaries, commands, execution posture, evidence posture, and projection surfaces for Shipper.",
  "canonicalNodes": [
    {
