      "storyPath": "$.story.asA",
      "statement": "Shipper is the conveyor character for release.",
      "nodeType": "identity"
    },
    {
      "canonicalPath": "$.shipper.allowedResponsibilities",
      "storyPath": "$.acceptanceCriteria[0]",
      "statement": "release packet; commit message; ship receipt; release gate enforcement",
      "nodeType": "allowed-responsibility"
    },
    {
      "canonicalPath": "$.shipper.forbiddenResponsibilities",
      "storyPath": "$.acceptanceCriteria[1]",
      "statement": "truth creation; evidence invention; canonical meaning; unverified shipping",
      "nodeType": "forbidden-responsibility"
    },
    {
      "canonicalPath": "$.shipper.commands",
      "storyPath": "$.story.iWant",
      "statement": "shipper.prepare-release; shipper.commit-message; shipper.ship",
      "nodeType": "command-surface"
    },
    {
      "canonicalPath": "$.shipper.execution.sej",
      "storyPath": "$.acceptanceCriteria[2]",
      "statement": "Executable behavior is declared in contracts/sej/shipper.execute.sej.v1.json.",
      "nodeType": "execution-authority"
    },
    {
      "canonicalPath": "$.shipper.projection",
      "storyPath": "$.acceptanceCriteria[3]",
      "statement": "Projected runtime surface targets generated/shipper/node/shipper.cjs.",
      "nodeType": "projection-surface"
    }
  ],
  "rules": [
    {
      "ruleKey": "rule.shipper.no-competing-narrative",
      "statement": "Shipper may not claim responsibilities outside its declared role."
    },
    {
      "ruleKey": "rule.shipper.receipt-required",
      "statement": "Outputs require receipts before downstream authority can pass."
    },
    {
      "ruleKey": "rule.shipper.fail-closed",
