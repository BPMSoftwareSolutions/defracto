{
  "schemaVersion": "defracto.story-stress-suite.v1",
  "suiteKey": "demo-suite",
  "title": "Story-To-TDD Conveyor Demo Stress Suite",
  "caseManifestPaths": [
    "stress-lab/story-cases/001-slug-generator/case.manifest.v1.json",
    "stress-lab/story-cases/002-resume-tailor/case.manifest.v1.json",
    "stress-lab/story-cases/003-red-green-validator/case.manifest.v1.json",
    "stress-lab/story-cases/004-provider-fallback/case.manifest.v1.json",
    "stress-lab/story-cases/005-ambiguous-story/case.manifest.v1.json"
  ],
  "requiredOutcomeClasses": [
    "passed",
    "fallback",
    "honest_blocked"
  ],
  "runDefaults": {
    "runnerMode": "live_cognitive_stress",
    "outputRoot": "stress-lab/runs",
    "dashboardProjection": "contracts/projections/stress-lab-dashboard.markdown-projection.v1.json"
  },
  "handoffPacketRequirements": {
    "packetSchema": "contracts/schemas/conveyor-stage-handoff-packet.schema.v1.json",
    "policy": "contracts/policies/conveyor-stage-handoff-packet-required.policy.v1.json",
    "gate": "contracts/gates/conveyor-stage-handoff-packet-required.gate.v1.json",
    "requiredPacketKinds": [
      "cognitive_candidate",
      "promoted_authority",
      "test_intent",
      "red_test",
      "implementation_candidate",
      "implementation_projection",
      "green_test",
      "sog_promotion"
    ],
    "suiteRunMustEmitPacketIndex": true,
    "blockerCodes": [
      "handoff_packet_missing",
      "handoff_packet_schema_invalid",
      "handoff_packet_required_receipt_missing",
      "handoff_packet_durable_truth_without_sog"
    ]
  },
  "completionCriteria": [
    "stress case manifests validate",
    "demo suite references valid cases",
    "expected outcomes include pass, honest block, fallback, and parity posture",
    "dashboard summarizes scenario status, fidelity, truth owner, blockers, and receipts",
    "catalog projection does not pretend to be live cognitive compile",
    "stage handoff packet index validates every conveyor stage boundary before release posture"
  ]
}
