{
  "schemaVersion": "defracto.cli-command-contract.v1",
  "cliKey": "defracto.cli.ndd-stress-run.v1",
  "commandKey": "defracto.ndd.stress.run.v1",
  "entrypoint": "ndd",
  "commandName": "ndd stress run",
  "status": "draft-ready-for-slice-054-review",
  "sourceTruth": "declared_json_contract",
  "purpose": "Declare the stress lab runner command for resolving a story stress suite, validating scenario manifests, emitting scenario receipts, and projecting a suite dashboard.",
  "argvPatterns": [
    "ndd stress run --suite <suitePath>",
    "ndd stress run --suite <suitePath> --run-date <yyyy-mm-dd>",
    "ndd stress run --suite <suitePath> --output-root <outputRoot>"
  ],
  "laneClassification": {
    "schemaVersion": "defracto.runner-lane-classification.v1",
    "laneMode": "live_cognitive_stress",
    "aiWorkerRequired": true,
    "requiredWorker": "defracto.workers.gemini_flash.v1",
    "requiredInvocationCapability": "worker.gemini_flash.invoke.v1",
    "fallbackAllowed": false,
    "mockAllowed": false,
    "staleResponseAllowed": false,
    "deterministicReplayAllowedForCreation": false,
    "requiredEvidence": [
      "stress suite manifest",
      "stress case manifests",
      "live cognitive provider invocation receipt",
      "fresh provider response receipt",
      "scenario result receipts",
      "suite run receipt",
      "dashboard projection"
    ],
    "blockerCodes": [
      "suite_path_missing",
      "suite_manifest_invalid",
      "case_manifest_missing",
      "case_manifest_invalid",
      "unsupported_scenario_mode",
      "scenario_source_story_missing",
      "scenario_fixture_missing",
      "dashboard_projection_failed",
      "live_cognitive_provider_capability_missing",
      "live_cognitive_provider_invocation_missing"
    ]
  },
  "boundedOutputs": [
    "stress-lab run summary JSON only after live cognitive invocation succeeds",
    "per-scenario result receipts",
    "Markdown dashboard projected from summary JSON",
    "suite-level run receipt"
  ],
  "forbiddenOutputs": [
    "cognitive compile truth without live provider receipt",
    "silent provider substitution",
    "generated code promoted as durable truth",
    "SOG promotion without declared parity posture"
  ],
  "failurePosture": "fail-closed",
  "completionPosture": "The stress runner is valid only as a live cognitive conveyor stress run; catalog projection alone cannot satisfy this command."
}
