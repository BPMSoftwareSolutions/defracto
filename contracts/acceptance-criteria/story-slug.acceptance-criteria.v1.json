    {
      "criteriaKey": "story-slug.lowercase-ascii",
      "statement": "The slug generator lowercases ASCII letters.",
      "observableBehavior": "Input `Story Title` produces lowercase letters in the slug key.",
      "preconditions": [
        "title input is non-empty"
      ],
      "inputs": [
        "Story Title"
      ],
      "expectedOutputs": [
        "story-title"
      ],
      "expectedResult": {
        "status": "passed",
        "slugKey": "story-title"
      },
      "negativeCases": [],
      "sourceTrace": {
        "sourcePath": "source/user-stories/story-slug.source.v1.md",
        "sourceHash": "sha256:785f1215944f2b5754aa32ef78308051b74e9291e9332a5d785172cc988917d9",
        "storyPath": "$.acceptanceCriteria[0]"
      },
      "canonicalTrace": {
        "canonicalSpecKey": "defracto.user-stories.story-slug.canonical-spec.v1",
        "canonicalPath": "$.storySlug.rules.lowercaseAscii"
      },
      "testIntentKeys": [
        "story-slug.test.lowercase-and-whitespace"
      ],
      "testability": {
        "status": "testable",
        "reason": "The lowercase transformation has deterministic input and output."
      }
    },
