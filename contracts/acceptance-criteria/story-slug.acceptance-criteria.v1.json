    {
      "criteriaKey": "story-slug.no-hand-authored-code",
      "statement": "The story-to-TDD conveyor must not introduce hand-authored runtime code, tests, or implementation files.",
      "observableBehavior": "Accepted code artifacts have projection manifests, materialization receipts, and conformance evidence.",
      "preconditions": [
        "generated test or generated implementation artifact is produced"
      ],
      "inputs": [
        "artifact path"
      ],
      "expectedOutputs": [
        "projection manifest exists",
        "materialization receipt exists",
        "artifact hash recorded"
      ],
      "expectedResult": {
        "requiredEvidence": [
          "projection manifest",
          "materialization receipt",
          "artifact hash"
        ]
      },
      "negativeCases": [
        "code artifact without receipt",
        "code artifact without projection manifest"
      ],
