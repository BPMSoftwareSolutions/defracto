    {
      "criteriaKey": "story-slug.empty-input-blocked",
      "statement": "The slug generator returns blocked for empty input.",
      "observableBehavior": "Blank input returns blocked status instead of a slug key.",
      "preconditions": [
        "title input is blank or whitespace only"
      ],
      "inputs": [
        ""
      ],
      "expectedOutputs": [
        "status blocked",
        "blocker empty_slug_input"
      ],
      "expectedResult": {
        "status": "blocked",
        "blocker": "empty_slug_input"
      },
      "negativeCases": [
        "empty slug",
        "passed status"
      ],
      "sourceTrace": {
        "sourcePath": "source/user-stories/story-slug.source.v1.md",
