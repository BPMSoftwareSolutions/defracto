    },
    "edgeKind": {
      "type": "string",
      "const": "visual-edge"
    },
    "fromNodeKey": {
      "type": "string"
    },
    "toNodeKey": {
      "type": "string"
    },
    "connector": {
      "type": "string"
    },
    "semanticMeaning": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
