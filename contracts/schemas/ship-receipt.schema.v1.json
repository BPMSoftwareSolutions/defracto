{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defracto.ship-receipt.v1",
  "title": "Ship Receipt",
  "type": "object",
  "required": [
    "schemaVersion",
    "receiptKey",
    "status",
    "checkedAt",
    "verificationStatus"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "defracto.ship-receipt.v1"
    },
    "receiptKey": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "blocked",
        "failed"
      ]
    },
    "checkedAt": {
      "type": "string"
    },
    "verificationStatus": {
      "type": "string",
      "enum": [
        "locally_verified",
        "externally_verified",
        "blocked",
        "not_executed"
      ]
    },
    "artifactHashes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "releasePacketPath": {
      "type": "string"
    },
    "commitMessagePath": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
