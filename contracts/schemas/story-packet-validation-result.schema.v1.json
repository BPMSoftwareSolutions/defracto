{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defracto.story-packet-validation-result.v1",
  "title": "Story Packet Validation Result",
  "type": "object",
  "required": [
    "schemaVersion",
    "resultKey",
    "status",
    "checkedAt",
    "mode",
    "source",
    "storyPacket",
    "findings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "resultKey": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "blocked",
        "deferred"
      ]
    },
    "checkedAt": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "manual-seed",
        "contract-review",
        "executable-run"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "sourceKey",
        "sourceHash",
        "sourcePath"
      ],
      "properties": {
        "sourceKey": {
          "type": "string"
        },
        "sourceHash": {
          "type": "string"
        },
        "sourcePath": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "storyPacket": {
      "type": "object",
      "required": [
        "storyKey",
        "storyPath",
        "derivedFrom"
      ],
      "properties": {
        "storyKey": {
          "type": "string"
        },
        "storyPath": {
          "type": "string"
        },
        "derivedFrom": {
          "type": "object",
          "required": [
            "sourceKey",
            "sourcePath"
          ],
          "properties": {
            "sourceKey": {
              "type": "string"
            },
            "sourcePath": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "findingKey",
          "message"
        ],
        "properties": {
          "findingKey": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
