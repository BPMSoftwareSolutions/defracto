{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Receipt Hash Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "enum": [
        "passed",
        "blocked"
      ]
    },
    "blocker": {
      "enum": [
        "malformed_receipt_hash",
        "missing_semantic_capability",
        "missing_sej_language_operation"
      ]
    }
  },
  "required": [
    "status"
  ]
}
