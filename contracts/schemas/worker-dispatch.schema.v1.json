    },
    "dispatchKey": {
      "type": "string"
    },
    "runKey": {
      "type": "string"
    },
    "laneKey": {
      "type": "string"
    },
    "workerKey": {
      "type": "string"
    },
    "inputArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expectedOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenResponsibilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
