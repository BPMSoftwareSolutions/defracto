      "type": "string"
    },
    "sourceKey": {
      "type": "string"
    },
    "sourceType": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "sourceHash": {
      "type": "string"
    },
    "capturedAt": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
