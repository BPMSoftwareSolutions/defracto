{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defracto.telemetry-observer.command-input.v1",
  "title": "Telemetry Observer Command Input",
  "type": "object",
  "required": [
    "schemaVersion",
    "commandKey",
    "runKey",
    "failClosed"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "defracto.telemetry-observer.command-input.v1"
    },
    "commandKey": {
      "type": "string",
      "enum": [
        "telemetry.capture",
        "telemetry.observe",
        "telemetry.promote-source"
      ]
    },
    "runKey": {
      "type": "string"
    },
    "runPath": {
      "type": "string"
    },
    "payload": {},
    "failClosed": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false
}
