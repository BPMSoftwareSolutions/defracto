{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defracto.story-slug-result.v1",
  "title": "Story Slug Result",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "status",
        "slugKey"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "passed"
        },
        "slugKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "status",
        "blocker"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "blocked"
        },
        "blocker": {
          "type": "string",
          "const": "empty_slug_input"
        }
      },
      "additionalProperties": false
    }
  ]
}
