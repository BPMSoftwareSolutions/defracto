{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defracto.telemetry-observation.v1",
  "title": "Telemetry Observation",
  "type": "object",
  "required": [
    "schemaVersion",
    "observationKey",
    "observedAt",
    "source",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "defracto.telemetry-observation.v1"
    },
    "observationKey": {
      "type": "string"
    },
    "observedAt": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "relatedRunKey": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
