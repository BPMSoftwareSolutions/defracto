  "requiredInputs": [
    "runManifest",
    "sourceStory",
    "buildSetup",
    "testResults",
    "reviewPackage",
    "receipts"
  ],
  "blockerCodes": [
    "artifact_outside_work_plan",
    "artifact_missing_receipt",
    "manual_run_manifest_created",
    "unreceipted_review_package",
    "agent_stitched_run_output"
  ],
  "completionPosture": "A Review Package may be accepted only when the conveyor-produced artifacts are listed, hashed, and receipted."
}
