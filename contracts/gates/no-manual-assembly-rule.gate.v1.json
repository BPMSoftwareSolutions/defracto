{
  "schemaVersion": "defracto.gate.v1",
  "gateKey": "defracto.gates.no-manual-assembly-rule.v1",
  "userFacingName": "No Manual Assembly Rule",
  "purpose": "Block review or acceptance when important artifacts appear without conveyor receipts.",
