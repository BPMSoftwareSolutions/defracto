{
  "schemaVersion": "loc.semantic-operation-graph.v1",
  "objectKind": "sej_code_body",
  "objectKey": "defracto.ndd-story-implement.execute.sog.v1",
  "sourceTruth": "sej_semantic_body",
  "status": "ready-for-manifest-aware-dispatch",
  "commandKey": "defracto.ndd.story.implement.v1",
  "bodyKind": "semantic_operation_graph",
  "hostLanguageBodyAllowed": false,
  "semanticActions": [
    {
      "actionKey": "defracto.ndd-story-implement.match-command.semantic-action.v1",
      "capabilityKey": "cli.argv.match.v1",
      "intent": "Match ndd story implement command boundary."
    },
    {
      "actionKey": "defracto.ndd-story-implement.select-target-graph.semantic-action.v1",
      "capabilityKey": "project.value.v1",
      "intent": "Select explicit target-kind graph, including Build Setup, or manifest-declared lane."
    },
    {
      "actionKey": "defracto.ndd-story-implement.execute-selected-graph.semantic-action.v1",
      "capabilityKey": "semantic.operation_graph.execute.v1",
      "intent": "Delegate story implement execution to the declared semantic graph selected by target-kind or manifest."
    }
  ],
  "graph": {
    "steps": [
      {
        "id": "matchStoryImplementCommand",
        "capabilityKey": "cli.argv.match.v1",
        "intent": "Match ndd story implement with a required slice key.",
        "input": {
          "argv": {
            "$context": "argv"
          },
          "patterns": [
            {
              "commandKey": "defracto.ndd.story.implement.v1",
              "tokens": [
                "story",
                "implement"
              ],
              "options": [
                {
                  "name": "text",
                  "required": false
                },
                {
                  "name": "source",
                  "required": false
                },
                {
                  "name": "target-kind",
                  "required": false
                },
                {
                  "name": "target-sdk",
                  "required": false
                },
                {
                  "name": "slice",
                  "required": true
                },
                {
                  "name": "source-script",
                  "required": false
                },
                {
                  "name": "capability",
                  "required": false
                }
              ]
            }
          ]
        },
        "output": {
          "path": "$graph.command"
        },
        "failure": {
          "status": "blocked",
          "blocker": "unsupported_story_implement_command"
        }
      },
      {
        "id": "selectStoryImplementTargetGraph",
        "capabilityKey": "project.value.v1",
        "intent": "Select semantic strategy, SDK capability forge, Build Setup, self-unblocking lab, release-grade product package, explicit visual proof, or manifest-declared lane from parsed command options.",
        "input": {
          "fields": {
            "routeKey": {
              "when": {
                "equals": [
                  {
                    "$graph": "command.options.target-kind"
                  },
                  {
                    "literal": "semantic-strategy"
                  }
                ]
              },
              "then": {
                "literal": "semantic_strategy_compile"
              },
              "else": {
                "when": {
                  "equals": [
                    {
                      "$graph": "command.options.target-kind"
                    },
                    {
                      "literal": "sdk-capability"
                    }
                  ]
                },
                "then": {
                  "literal": "sdk_capability_forge"
                },
                "else": {
                  "when": {
                    "equals": [
                      {
                        "$graph": "command.options.target-kind"
                      },
                      {
                        "literal": "build-setup"
                      }
                    ]
                  },
                  "then": {
                    "literal": "build_setup"
                  },
                  "else": {
                    "when": {
                      "equals": [
                        {
                          "$graph": "command.options.target-kind"
                        },
                        {
                          "literal": "cognitive-ba-lane"
                        }
                      ]
                    },
                    "then": {
                      "literal": "cognitive_ba_lane_authoring"
                    },
                    "else": {
                      "when": {
                        "equals": [
                          {
                            "$graph": "command.options.target-kind"
                          },
                          {
                            "literal": "cognitive-ba-live"
                          }
                        ]
                      },
                        "then": {
                          "literal": "cognitive_ba_live_proof"
                        },
                            "else": {
                              "when": {
                                "equals": [
                                  {
                                    "$graph": "command.options.target-kind"
                                  },
                                  {
                                    "literal": "cognitive-ba-visual-proof"
                                  }
                                ]
                              },
                              "then": {
                                "literal": "cognitive_ba_visual_proof"
                              },
                              "else": {
                                "when": {
                                  "equals": [
                                    {
                                      "$graph": "command.options.target-kind"
                                    },
                                    {
                                      "literal": "vendor-evidence-readiness-sdk"
                                    }
                                  ]
                                },
                                "then": {
                                  "literal": "vendor_evidence_readiness_sdk"
                                },
                                "else": {
                                  "when": {
                                    "equals": [
                                      {
                                        "$graph": "command.options.target-kind"
                                      },
                                      {
                                        "literal": "self-unblocking-lab"
                                      }
                                    ]
                                  },
                                  "then": {
                                    "literal": "self_unblocking_lab"
                                  },
                                  "else": {
                                    "when": {
                                      "equals": [
                                        {
                                          "$graph": "command.options.target-kind"
                                        },
                                        {
                                        "literal": "invoice-approval-readiness-sdk"
                                      }
                                    ]
                                  },
                                    "then": {
                                      "literal": "invoice_approval_readiness_sdk"
                                    },
                                    "else": {
                                      "when": {
                                        "equals": [
                                          {
                                            "$graph": "command.options.target-kind"
                                          },
                                          {
                                            "literal": "node-script-replacement-acceptance"
                                          }
                                        ]
                                      },
                                      "then": {
                                        "literal": "node_script_replacement_acceptance"
                                      },
                                      "else": {
                                        "when": {
                                          "equals": [
                                            {
                                              "$graph": "command.options.target-kind"
                                            },
                                            {
                                              "literal": "runtime-surface-operation-binding"
                                            }
                                          ]
                                        },
                                        "then": {
                                          "literal": "runtime_surface_operation_binding"
                                        },
                                        "else": {
                                          "when": {
                                            "equals": [
                                              {
                                                "$graph": "command.options.target-kind"
                                              },
                                              {
                                                "literal": "node-script-to-sej-refactor"
                                              }
                                            ]
                                          },
                                          "then": {
                                            "literal": "node_script_to_sej_refactor"
                                          },
                                          "else": {
                                            "when": {
                                              "equals": [
                                                {
                                                  "$graph": "command.options.target-kind"
                                                },
                                                {
                                                  "literal": "visual-proof"
                                                }
                                              ]
                                            },
                                            "then": {
                                              "literal": "visual_proof_materialization"
                                            },
                                            "else": {
                                              "literal": "manifest_declared_lane"
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                      }
                    }
                }
              }
            },
            "graphRef": {
              "when": {
                "equals": [
                  {
                    "$graph": "command.options.target-kind"
                  },
                  {
                    "literal": "semantic-strategy"
                  }
                ]
              },
              "then": {
                "literal": {
                  "$inline": "contracts/semantic-operation-graphs/strategy/semantic-strategy-plan-materialize.sog.v1.json"
                }
              },
              "else": {
                "when": {
                  "equals": [
                    {
                      "$graph": "command.options.target-kind"
                    },
                    {
                      "literal": "sdk-capability"
                    }
                  ]
                },
                "then": {
                  "literal": {
                    "$inline": "contracts/semantic-operation-graphs/sdk/sdk-capability-forge.sog.v1.json"
                  }
                },
                "else": {
                  "when": {
                    "equals": [
                      {
                        "$graph": "command.options.target-kind"
                      },
                      {
                        "literal": "build-setup"
                      }
                    ]
                  },
                  "then": {
                    "literal": {
                      "$inline": "contracts/semantic-operation-graphs/build/build-setup.execute.sog.v1.json"
                    }
                  },
                  "else": {
                    "when": {
                      "equals": [
                        {
                          "$graph": "command.options.target-kind"
                        },
                        {
                          "literal": "cognitive-ba-lane"
                        }
                      ]
                    },
                    "then": {
                      "literal": {
                        "$inline": "contracts/semantic-operation-graphs/build/cognitive-ba-lane-authoring.execute.sog.v1.json"
                      }
                    },
                    "else": {
                      "when": {
                        "equals": [
                          {
                            "$graph": "command.options.target-kind"
                          },
                          {
                            "literal": "cognitive-ba-live"
                          }
                        ]
                      },
                        "then": {
                          "literal": {
                            "$inline": "contracts/semantic-operation-graphs/build/live-cognitive-ba-proof.execute.sog.v1.json"
                          }
                        },
                            "else": {
                              "when": {
                                "equals": [
                                  {
                                    "$graph": "command.options.target-kind"
                                  },
                                  {
                                    "literal": "cognitive-ba-visual-proof"
                                  }
                                ]
                              },
                              "then": {
                                "literal": {
                                  "$inline": "contracts/semantic-operation-graphs/build/live-cognitive-ba-visual-proof.execute.sog.v1.json"
                                }
                              },
                              "else": {
                                "when": {
                                  "equals": [
                                    {
                                      "$graph": "command.options.target-kind"
                                    },
                                    {
                                      "literal": "vendor-evidence-readiness-sdk"
                                    }
                                  ]
                                },
                                "then": {
                                  "literal": {
                                    "$inline": "contracts/semantic-operation-graphs/sdk/vendor-evidence-readiness-review-package.sog.v1.json"
                                  }
                                },
                                "else": {
                                  "when": {
                                    "equals": [
                                      {
                                        "$graph": "command.options.target-kind"
                                      },
                                      {
                                        "literal": "self-unblocking-lab"
                                      }
                                    ]
                                  },
                                  "then": {
                                    "literal": {
                                      "$inline": "contracts/semantic-operation-graphs/lab/self-unblocking-lab.execute.sog.v1.json"
                                    }
                                  },
                                  "else": {
                                    "when": {
                                      "equals": [
                                        {
                                          "$graph": "command.options.target-kind"
                                        },
                                        {
                                        "literal": "invoice-approval-readiness-sdk"
                                      }
                                    ]
                                  },
                                    "then": {
                                      "literal": {
                                        "$inline": "contracts/semantic-operation-graphs/sdk/invoice-approval-readiness-release-package.sog.v1.json"
                                      }
                                    },
                                    "else": {
                                      "when": {
                                        "equals": [
                                          {
                                            "$graph": "command.options.target-kind"
                                          },
                                          {
                                            "literal": "node-script-replacement-acceptance"
                                          }
                                        ]
                                      },
                                      "then": {
                                        "literal": {
                                          "$inline": "contracts/semantic-operation-graphs/lab/node-script-replacement-acceptance.execute.sog.v1.json"
                                        }
                                      },
                                      "else": {
                                        "when": {
                                          "equals": [
                                            {
                                              "$graph": "command.options.target-kind"
                                            },
                                            {
                                              "literal": "runtime-surface-operation-binding"
                                            }
                                          ]
                                        },
                                        "then": {
                                          "literal": {
                                            "$inline": "contracts/semantic-operation-graphs/runtime-surface/runtime-surface-operation-binding.execute.sog.v1.json"
                                          }
                                        },
                                        "else": {
                                          "when": {
                                            "equals": [
                                              {
                                                "$graph": "command.options.target-kind"
                                              },
                                              {
                                                "literal": "node-script-to-sej-refactor"
                                              }
                                            ]
                                          },
                                          "then": {
                                            "literal": {
                                              "$inline": "contracts/semantic-operation-graphs/lab/node-script-to-sej-refactor.execute.sog.v1.json"
                                            }
                                          },
                                          "else": {
                                            "when": {
                                              "equals": [
                                                {
                                                  "$graph": "command.options.target-kind"
                                                },
                                                {
                                                  "literal": "visual-proof"
                                                }
                                              ]
                                            },
                                            "then": {
                                              "literal": {
                                                "$inline": "contracts/semantic-operation-graphs/projections/visual-proof-materialize.sog.v1.json"
                                              }
                                            },
                                            "else": {
                                              "literal": {
                                                "$inline": "contracts/semantic-operation-graphs/cli/ndd-story-implement-manifest-lane.execute.sog.v1.json"
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                      }
                  }
                }
              }
            }
          }
        },
        "output": {
          "path": "$graph.targetRoute"
        }
      },
      {
        "id": "executeSelectedStoryImplementGraph",
        "capabilityKey": "semantic.operation_graph.execute.v1",
        "intent": "Execute the selected story implement semantic graph.",
        "input": {
          "graphRef": {
            "$graph": "targetRoute.graphRef"
          },
          "context": {
            "argv": {
              "$context": "argv"
            },
            "command": {
              "$graph": "command"
            },
            "targetRoute": {
              "$graph": "targetRoute"
            }
          }
        },
        "output": {
          "path": "$graph.storyImplementResult"
        },
        "failure": {
          "status": "blocked",
          "blocker": "story_implement_semantic_graph_failed"
        }
      }
    ],
    "return": {
      "$result": true
    }
  },
  "evidenceObligations": [
    "story_implement_command_matched",
    "story_implement_target_graph_selected",
    "manifest_backed_story_implement_loads_run_manifest_when_target_kind_is_absent",
    "story_implement_does_not_default_to_visual_proof_materializer",
    "selected_story_implement_graph_executed_or_blocks_closed",
    "build_setup_route_delegates_to_build_setup_sog",
    "self_unblocking_lab_route_delegates_to_self_unblocking_lab_sog",
    "invoice_approval_readiness_sdk_route_delegates_to_release_package_sog",
    "node_script_to_sej_refactor_route_delegates_to_refactor_sog"
  ],
  "forbiddenClaims": [
    "generated CLI facade owns story implement behavior",
    "story implement command bypasses semantic operation graph",
    "story implement default route is visual proof materialization",
    "semantic strategy compile creates durable product truth",
    "sdk capability forge creates host-language product body",
    "provider candidate grants authority without hardening"
  ],
  "completionPosture": "ndd story implement delegates to an explicit target-kind graph, including the product-facing Build Setup lane, self-unblocking lab lane, invoice approval release package lane, and node-script-to-SEJ refactor lane, or to the manifest-declared lane. Missing or unsupported manifest lanes block closed."
}
