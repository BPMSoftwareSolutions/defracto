{
  "schemaVersion": "loc.semantic-operation-graph.v1",
  "objectKind": "sej_code_body",
  "objectKey": "defracto.ndd-story-implement.execute.sog.v1",
  "sourceTruth": "sej_semantic_body",
  "status": "ready-for-semantic-strategy-route",
  "commandKey": "defracto.ndd.story.implement.v1",
  "bodyKind": "semantic_operation_graph",
  "hostLanguageBodyAllowed": false,
  "semanticActions": [
    {
      "actionKey": "defracto.ndd-story-implement.match-command.semantic-action.v1",
      "capabilityKey": "cli.argv.match.v1",
      "intent": "Match ndd story implement command boundary."
    },
    {
      "actionKey": "defracto.ndd-story-implement.select-target-graph.semantic-action.v1",
      "capabilityKey": "project.value.v1",
      "intent": "Select visual proof or semantic strategy implementation graph from target-kind."
    },
    {
      "actionKey": "defracto.ndd-story-implement.execute-visual-proof.semantic-action.v1",
      "capabilityKey": "semantic.operation_graph.execute.v1",
      "intent": "Delegate story implement execution to the declared semantic graph selected by target-kind."
    }
  ],
  "graph": {
    "steps": [
      {
        "id": "matchStoryImplementCommand",
        "capabilityKey": "cli.argv.match.v1",
        "intent": "Match ndd story implement --text or --source with a required slice key.",
        "input": {
          "argv": {
            "$context": "argv"
          },
          "patterns": [
            {
              "commandKey": "defracto.ndd.story.implement.v1",
              "tokens": [
                "story",
                "implement"
              ],
              "options": [
                {
                  "name": "text",
                  "required": false
                },
                {
                  "name": "source",
                  "required": false
                },
                {
                  "name": "target-kind",
                  "required": false
                },
                {
                  "name": "slice",
                  "required": true
                }
              ]
            }
          ]
        },
        "output": {
          "path": "$graph.command"
        },
        "failure": {
          "status": "blocked",
          "blocker": "unsupported_story_implement_command"
        }
      },
      {
        "id": "selectStoryImplementTargetGraph",
        "capabilityKey": "project.value.v1",
        "intent": "Select semantic strategy graph when --target-kind semantic-strategy is present; otherwise keep the live visual proof materialization path.",
        "input": {
          "fields": {
            "routeKey": {
              "when": {
                "anyOf": [
                  {
                    "allOf": [
                      {
                        "equals": [
                          "$context.argv.2",
                          {
                            "literal": "--target-kind"
                          }
                        ]
                      },
                      {
                        "equals": [
                          "$context.argv.3",
                          {
                            "literal": "semantic-strategy"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "allOf": [
                      {
                        "equals": [
                          "$context.argv.4",
                          {
                            "literal": "--target-kind"
                          }
                        ]
                      },
                      {
                        "equals": [
                          "$context.argv.5",
                          {
                            "literal": "semantic-strategy"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              "then": {
                "literal": "semantic_strategy_compile"
              },
              "else": {
                "literal": "visual_proof_materialization"
              }
            },
            "graphRef": {
              "when": {
                "anyOf": [
                  {
                    "allOf": [
                      {
                        "equals": [
                          "$context.argv.2",
                          {
                            "literal": "--target-kind"
                          }
                        ]
                      },
                      {
                        "equals": [
                          "$context.argv.3",
                          {
                            "literal": "semantic-strategy"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "allOf": [
                      {
                        "equals": [
                          "$context.argv.4",
                          {
                            "literal": "--target-kind"
                          }
                        ]
                      },
                      {
                        "equals": [
                          "$context.argv.5",
                          {
                            "literal": "semantic-strategy"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              "then": {
                "literal": {
                  "$inline": "contracts/semantic-operation-graphs/strategy/semantic-strategy-plan-materialize.sog.v1.json"
                }
              },
              "else": {
                "literal": {
                  "$inline": "contracts/semantic-operation-graphs/projections/visual-proof-materialize.sog.v1.json"
                }
              }
            }
          }
        },
        "output": {
          "path": "$graph.targetRoute"
        }
      },
      {
        "id": "executeSelectedStoryImplementGraph",
        "capabilityKey": "semantic.operation_graph.execute.v1",
        "intent": "Execute the selected story implement semantic graph.",
        "input": {
          "graphRef": {
            "$graph": "targetRoute.graphRef"
          },
          "context": {
            "argv": {
              "$context": "argv"
            },
            "command": {
              "$graph": "command"
            }
          }
        },
        "output": {
          "path": "$graph.storyImplementResult"
        },
        "failure": {
          "status": "blocked",
          "blocker": "story_implement_semantic_graph_failed"
        }
      }
    ],
    "return": {
      "$result": true
    }
  },
  "evidenceObligations": [
    "story_implement_command_matched",
    "story_implement_target_graph_selected",
    "selected_story_implement_graph_executed",
    "stage_handoff_packets_materialized",
    "ascii_and_html_surfaces_materialized_from_same_model_or_semantic_strategy_plan_materialized"
  ],
  "forbiddenClaims": [
    "generated CLI facade owns story implement behavior",
    "story implement command bypasses semantic operation graph",
    "semantic strategy compile creates durable product truth",
    "ASCII and HTML materialized from different visual models",
    "provider candidate grants authority without hardening"
  ],
  "completionPosture": "ndd story implement delegates to the selected semantic graph and returns either visual proof materialization or semantic strategy compile result."
}
