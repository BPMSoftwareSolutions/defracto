{
  "schemaVersion": "loc.semantic-operation-graph.v1",
  "objectKind": "sej_code_body",
  "objectKey": "defracto.ndd-story-implement.manifest-declared-lane.sog.v1",
  "sourceTruth": "sej_semantic_body",
  "status": "ready-for-resolver",
  "commandKey": "defracto.ndd.story.implement.manifest-declared-lane.v1",
  "bodyKind": "semantic_operation_graph",
  "hostLanguageBodyAllowed": false,
  "semanticActions": [
    {
      "actionKey": "defracto.ndd-story-implement.manifest.match-command.v1",
      "capabilityKey": "cli.argv.match.v1",
      "intent": "Match manifest-backed story implement command."
    },
    {
      "actionKey": "defracto.ndd-story-implement.manifest.load.v1",
      "capabilityKey": "conveyor.run_manifest.load.v1",
      "intent": "Load the bootstrapped run manifest by slice key."
    },
    {
      "actionKey": "defracto.ndd-story-implement.manifest.execute-declared-lane.v1",
      "capabilityKey": "semantic.operation_graph.execute.v1",
      "intent": "Execute the story implement semantic graph declared by the loaded run manifest."
    }
  ],
  "graph": {
    "steps": [
      {
        "id": "matchManifestBackedStoryImplementCommand",
        "capabilityKey": "cli.argv.match.v1",
        "input": {
          "argv": {
            "$context": "argv"
          },
          "patterns": [
            {
              "commandKey": "defracto.ndd.story.implement.manifest-declared-lane.v1",
              "tokens": [
                "story",
                "implement"
              ],
              "options": [
                {
                  "name": "slice",
                  "required": true
                }
              ]
            }
          ]
        },
        "output": {
          "path": "$graph.command"
        }
      },
      {
        "id": "loadStoryRunManifest",
        "capabilityKey": "conveyor.run_manifest.load.v1",
        "input": {
          "sliceKey": {
            "$graph": "command.options.slice"
          },
          "defaultSearchRoot": {
            "literal": "conveyor/runs"
          }
        },
        "output": {
          "path": "$graph.runManifest"
        }
      },
      {
        "id": "executeManifestDeclaredStoryImplementLane",
        "capabilityKey": "semantic.operation_graph.execute.v1",
        "input": {
          "graphRef": {
            "$graph": "runManifest.stages.storyImplement.graphRef"
          },
          "context": {
            "argv": {
              "$context": "argv"
            },
            "command": {
              "$graph": "command"
            },
            "runManifest": {
              "$graph": "runManifest"
            },
            "targetRoute": {
              "literal": {
                "routeKey": "manifest_declared_lane"
              }
            }
          }
        },
        "output": {
          "path": "$graph.manifestLaneResult"
        },
        "failure": {
          "status": "blocked",
          "blocker": "manifest_declared_lane_execution_failed"
        }
      }
    ],
    "return": {
      "$result": true
    }
  },
  "evidenceObligations": [
    "story_implement_manifest_route_loads_run_manifest",
    "manifest_declared_lane_graph_ref_loaded",
    "manifest_declared_lane_executed_or_blocks_closed",
    "visual_proof_materializer_not_selected_by_default"
  ],
  "forbiddenClaims": [
    "manifest route creates durable authority",
    "manifest route defaults to visual proof",
    "manifest route invents undeclared downstream lane"
  ],
  "completionPosture": "This SOG loads the bootstrapped run manifest and delegates to the semantic graph declared by the manifest; missing or failing declared lanes block closed."
}
