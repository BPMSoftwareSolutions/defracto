              "#!/usr/bin/env node\n",
              "// GENERATED BY DEFRACTO SEJ MATERIALIZATION. DO NOT EDIT.\n",
              "// proofSurfaceOnly: true\n",
              "'use strict';\n",
              "const fs = require('node:fs');\n",
              "const input = JSON.parse(fs.readFileSync(0, 'utf8') || '{}');\n",
              "const required = input.requiredDocuments || [];\n",
              "const documents = input.documents || [];\n",
              "const claims = input.claims || [];\n",
              "const missingDocuments = required.filter((name) => !documents.includes(name));\n",
              "const checklist = required.map((name) => ({ name, present: documents.includes(name) }));\n",
              "const unsupportedClaims = [];\n",
              "if (claims.includes('SOC 2 compliant') && !documents.includes('SOC 2 Type II Report')) unsupportedClaims.push({ claim: 'SOC 2 compliant', reason: 'SOC 2 Type II Report missing' });\n",
              "const blocked = missingDocuments.length > 0 || unsupportedClaims.length > 0;\n",
              "const result = {\n",
              "  schemaVersion: 'defracto.vendor-evidence-readiness.result.v1',\n",
              "  status: blocked ? 'blocked' : 'passed',\n",
              "  blocker: blocked ? 'missing_required_vendor_evidence' : null,\n",
              "  vendorName: input.vendorName || 'Unknown Vendor',\n",
              "  checklist,\n",
              "  missingDocuments,\n",
              "  unsupportedClaims,\n",
              "  nextAction: blocked ? 'Vendor must provide missing required evidence before security review.' : 'Ready for security review.',\n",
              "  proofSurfaceOnly: true\n",
              "};\n",
              "process.stdout.write(JSON.stringify(result));"
            ]
