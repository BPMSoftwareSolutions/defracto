        "id": "loadSdkCapabilityRunManifest",
        "capabilityKey": "conveyor.run_manifest.load.v1",
        "intent": "Load the SDK capability run manifest by CLI slice key.",
        "input": {
          "sliceKey": {
            "$context": "command.options.slice"
          },
          "defaultSearchRoot": "conveyor/runs"
        },
        "output": {
          "path": "$graph.runManifest"
        },
        "failure": {
          "status": "blocked",
          "blocker": "sdk_capability_run_manifest_missing"
        }
      },
      {
        "id": "verifyCognitiveTrace",
        "capabilityKey": "evidence.receipt.verify.v1",
        "intent": "Verify cognitive/provider participation receipts referenced by the run manifest.",
        "input": {
          "receipts": {
            "$graph": "runManifest.providerReceiptRefs"
          },
          "hashes": []
