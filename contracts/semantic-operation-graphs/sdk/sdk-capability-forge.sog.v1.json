                },
                "report": {
                  "$graph": "runManifest.paths.report"
                }
              }
            },
            "findings": [
              {
                "severity": "blocker",
                "code": "missing_semantic_capability",
                "message": {
                  "$graph": "runManifest.blockedFindingMessage"
                },
                "details": {
                  "requiredCapability": {
                    "$graph": "runManifest.requiredCapability"
                  },
                  "nearbyCapabilityRejected": {
                    "$graph": "runManifest.nearbyCapabilityRejected"
                  }
                }
              }
            ],
            "blocker": "missing_semantic_capability",
            "error": {
