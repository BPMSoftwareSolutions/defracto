                  "hash": {
                    "$graph": "sdkStrategyHash.hash"
                  }
                },
                "capabilityGap": {
                  "path": {
                    "$graph": "runManifest.paths.capabilityGap"
                  },
                  "hash": {
                    "$graph": "capabilityGapHash.hash"
                  }
                },
                "receiptHashSog": {
                  "path": {
                    "$graph": "runManifest.paths.receiptHashSog"
                  },
                  "hash": {
                    "$graph": "receiptHashSogHash.hash"
                  }
                }
              },
              "completionPosture": {
