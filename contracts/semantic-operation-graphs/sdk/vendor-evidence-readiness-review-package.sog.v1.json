            "joinWith": "\n",
            "contentRef": [
              "#!/usr/bin/env node",
              "// GENERATED BY DEFRACTO SEJ MATERIALIZATION. DO NOT EDIT.",
              "// proofSurfaceOnly: true",
              "'use strict';",
              "const fs = require('node:fs');",
              "const input = JSON.parse(fs.readFileSync(0, 'utf8') || '{}');",
              "const required = input.requiredDocuments || [];",
              "const documents = input.documents || [];",
              "const claims = input.claims || [];",
              "const missingDocuments = required.filter((name) => !documents.includes(name));",
              "const checklist = required.map((name) => ({ name, present: documents.includes(name) }));",
              "const unsupportedClaims = [];",
              "if (claims.includes('SOC 2 compliant') && !documents.includes('SOC 2 Type II Report')) unsupportedClaims.push({ claim: 'SOC 2 compliant', reason: 'SOC 2 Type II Report missing' });",
              "const blocked = missingDocuments.length > 0 || unsupportedClaims.length > 0;",
              "const result = {",
              "  schemaVersion: 'defracto.vendor-evidence-readiness.result.v1',",
              "  status: blocked ? 'blocked' : 'passed',",
              "  blocker: blocked ? 'missing_required_vendor_evidence' : null,",
              "  vendorName: input.vendorName || 'Unknown Vendor',",
              "  checklist,",
              "  missingDocuments,",
              "  unsupportedClaims,",
              "  nextAction: blocked ? 'Vendor must provide missing required evidence before security review.' : 'Ready for security review.',",
              "  proofSurfaceOnly: true",
              "};",
              "process.stdout.write(JSON.stringify(result));"
            ]
          }
        },
        "output": {
          "path": "$graph.workerArtifact"
