              "<style>body{margin:0;background:#f5f7fb;color:#17202a;font-family:Arial,sans-serif}main{max-width:1120px;margin:0 auto;padding:32px}.hero{background:#fff;border:1px solid #d8dee9;padding:28px;margin-bottom:16px}.title{font-size:34px;font-weight:800;margin:0}.subtitle{color:#4b5563;font-size:16px}.badge{display:inline-block;padding:6px 10px;border-radius:6px;font-weight:700}.blocked{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}.passed{background:#dcfce7;color:#166534;border:1px solid #bbf7d0}.grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}.panel{background:#fff;border:1px solid #d8dee9;padding:20px}.panel h2{font-size:19px;margin:0 0 12px}.check{display:flex;justify-content:space-between;border-bottom:1px solid #eef1f5;padding:9px 0}.ok{color:#166534;font-weight:700}.bad{color:#991b1b;font-weight:700}.flow{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;align-items:center}.flow div{background:#eef2f7;border:1px solid #cbd5e1;text-align:center;padding:12px;font-weight:700}.arrow{background:transparent!important;border:0!important;color:#64748b}.wide{grid-column:1/-1}code{background:#eef2f7;padding:2px 4px}table{border-collapse:collapse;width:100%}td,th{border:1px solid #d8dee9;padding:8px;text-align:left;vertical-align:top}th{background:#eef2f7}@media(max-width:780px){.grid{grid-template-columns:1fr}.flow{grid-template-columns:1fr}.arrow{display:none}}</style>",
