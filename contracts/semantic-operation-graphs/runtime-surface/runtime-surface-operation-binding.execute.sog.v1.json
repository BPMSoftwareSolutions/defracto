              "#!/usr/bin/env node\n",
              "// GENERATED BY DEFRACTO RUNTIME-SURFACE BINDING. DO NOT EDIT.\n",
              "// Generic adapter; product rules are loaded from the binding registry.\n",
              "'use strict';\n",
              "const fs = require('node:fs');\n",
              "const registry = JSON.parse(fs.readFileSync('",
              {
                "$graph": "bindingRegistryPath.path"
              },
              "', 'utf8'));\n",
              "const input = JSON.parse(fs.readFileSync(0, 'utf8') || '{}');\n",
              "function readField(object, field, fallback) { return object && Object.prototype.hasOwnProperty.call(object, field) ? object[field] : fallback; }\n",
              "function asArray(value) { return Array.isArray(value) ? value : []; }\n",
              "function contains(array, value) { return asArray(array).some((item) => JSON.stringify(item) === JSON.stringify(value)); }\n",
              "function filter(array, predicate) { return asArray(array).filter(predicate); }\n",
              "function any(values) { return asArray(values).some(Boolean); }\n",
              "function project(fields) { return fields; }\n",
              "const target = registry.targetBehavior;\n",
              "const vendorName = readField(input, target.fields.vendorName, 'Unknown Vendor');\n",
              "const documents = asArray(readField(input, target.fields.documents, []));\n",
              "const claims = asArray(readField(input, target.fields.claims, []));\n",
              "const required = asArray(readField(input, target.fields.requiredDocuments, []));\n",
              "const missingDocuments = filter(required, (name) => !contains(documents, name));\n",
              "const checklist = required.map((name) => ({ name, present: contains(documents, name) }));\n",
              "const unsupportedClaims = filter(target.unsupportedClaimRules, (rule) => contains(claims, rule.claim) && !contains(documents, rule.requiresDocument)).map((rule) => ({ claim: rule.claim, reason: rule.reasonWhenMissing }));\n",
              "const blocked = any([missingDocuments.length > 0, unsupportedClaims.length > 0]);\n",
              "const result = project({ schemaVersion: target.schemaVersion, status: blocked ? 'blocked' : 'passed', blocker: blocked ? target.blocked.blocker : null, vendorName, checklist, missingDocuments, unsupportedClaims, nextAction: blocked ? target.blocked.nextAction : target.passed.nextAction, proofSurfaceOnly: true });\n",
              "process.stdout.write(JSON.stringify(result));\n"
            ]
