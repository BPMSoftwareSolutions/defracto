{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.ndd-cli.resolve-run-mode.semantic-action.v1",
  "capabilityKey": "cli.resolve_run_mode.v1",
  "intent": "Resolve sync/async/status/review command mode from input.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.resolve_run_mode"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "ndd_cli_resolve_run_mode_blocked"
  }
}
