{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.ndd-cli.parse-command-boundary.semantic-action.v1",
  "capabilityKey": "cli.parse_command_boundary.v1",
  "intent": "Parse operator command boundary without owning meaning.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.parse_command_boundary"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "ndd_cli_parse_command_boundary_blocked"
  }
}
