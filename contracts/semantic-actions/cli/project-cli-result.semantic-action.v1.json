{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.ndd-cli.project-cli-result.semantic-action.v1",
  "capabilityKey": "project.value.v1",
  "intent": "Project CLI command result from runner output.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.project_cli_result"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "ndd_cli_project_cli_result_blocked"
  }
}
