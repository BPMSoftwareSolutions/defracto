{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.evidence-inspector.verify-receipts.semantic-action.v1",
  "capabilityKey": "evidence.verify_receipt_set.v1",
  "intent": "Verify required receipts exist and pass.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.verify_receipts"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "evidence_inspector_verify_receipts_blocked"
  }
}
