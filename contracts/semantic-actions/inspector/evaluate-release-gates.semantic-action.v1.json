{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.evidence-inspector.evaluate-release-gates.semantic-action.v1",
  "capabilityKey": "evaluate.predicate.v1",
  "intent": "Evaluate release gates.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.evaluate_release_gates"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "evidence_inspector_evaluate_release_gates_blocked"
  }
}
