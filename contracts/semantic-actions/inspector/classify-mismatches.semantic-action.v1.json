{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.evidence-inspector.classify-mismatches.semantic-action.v1",
  "capabilityKey": "content.disposition_classify.v1",
  "intent": "Classify content mismatches.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.classify_mismatches"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "evidence_inspector_classify_mismatches_blocked"
  }
}
