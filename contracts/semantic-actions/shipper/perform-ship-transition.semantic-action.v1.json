{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.shipper.perform-ship-transition.semantic-action.v1",
  "capabilityKey": "ship.transition.v1",
  "intent": "Perform authorized ship transition.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.perform_ship_transition"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "shipper_perform_ship_transition_blocked"
  }
}
