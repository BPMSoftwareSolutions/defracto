{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.lane-workers.resolve-worker-profile.semantic-action.v1",
  "capabilityKey": "resolve.contract.v1",
  "intent": "Resolve worker profile and response contract.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.resolve_worker_profile"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "lane_workers_resolve_worker_profile_blocked"
  }
}
