{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.lane-workers.project-worker-response.semantic-action.v1",
  "capabilityKey": "project.value.v1",
  "intent": "Project lane-scoped worker response shape.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.project_worker_response"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "lane_workers_project_worker_response_blocked"
  }
}
