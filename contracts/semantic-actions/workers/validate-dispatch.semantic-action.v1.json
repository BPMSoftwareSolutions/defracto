{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.lane-workers.validate-dispatch.semantic-action.v1",
  "capabilityKey": "object.require_fields.v1",
  "intent": "Validate required dispatch fields.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.validate_dispatch"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "lane_workers_validate_dispatch_blocked"
  }
}
