{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.conveyor-runner.find-next-lane.semantic-action.v1",
  "capabilityKey": "array.first_matching.v1",
  "intent": "Find the next pending lane.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.find_next_lane"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "conveyor_runner_find_next_lane_blocked"
  }
}
