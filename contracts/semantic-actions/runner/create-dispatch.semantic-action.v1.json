{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.conveyor-runner.create-dispatch.semantic-action.v1",
  "capabilityKey": "project.value.v1",
  "intent": "Project lane dispatch packet.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.create_dispatch"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "conveyor_runner_create_dispatch_blocked"
  }
}
