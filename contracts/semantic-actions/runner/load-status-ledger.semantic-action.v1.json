{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.conveyor-runner.load-status-ledger.semantic-action.v1",
  "capabilityKey": "json.read.v1",
  "intent": "Load or initialize the status ledger.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.load_status_ledger"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "conveyor_runner_load_status_ledger_blocked"
  }
}
