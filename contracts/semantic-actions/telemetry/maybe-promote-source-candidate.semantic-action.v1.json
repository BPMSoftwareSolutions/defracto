{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.telemetry-observer.maybe-promote-source-candidate.semantic-action.v1",
  "capabilityKey": "telemetry.promote_source_candidate.v1",
  "intent": "Create source promotion candidate when authorized.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.maybe_promote_source_candidate"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "telemetry_observer_maybe_promote_source_candidate_blocked"
  }
}
