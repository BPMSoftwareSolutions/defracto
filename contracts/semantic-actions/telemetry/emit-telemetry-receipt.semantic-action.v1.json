{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.telemetry-observer.emit-telemetry-receipt.semantic-action.v1",
  "capabilityKey": "evidence.emit.v1",
  "intent": "Emit telemetry receipt.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.emit_telemetry_receipt"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "telemetry_observer_emit_telemetry_receipt_blocked"
  }
}
