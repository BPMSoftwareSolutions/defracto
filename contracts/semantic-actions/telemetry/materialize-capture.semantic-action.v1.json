{
  "schemaVersion": "loc.semantic-action.v1",
  "objectKind": "semantic_action",
  "actionKey": "defracto.telemetry-observer.materialize-capture.semantic-action.v1",
  "capabilityKey": "artifact.materialize.v1",
  "intent": "Materialize telemetry capture.",
  "stableSignature": {
    "algorithm": "sha256",
    "fields": [
      "actionKey",
      "capabilityKey",
      "input",
      "output",
      "failure"
    ],
    "value": "computed-by-resolver-or-registry"
  },
  "input": {
    "context": "$context",
    "graph": "$graph"
  },
  "output": {
    "path": "$graph.materialize_capture"
  },
  "failure": {
    "onMissingInput": "blocked",
    "blocker": "telemetry_observer_materialize_capture_blocked"
  }
}
