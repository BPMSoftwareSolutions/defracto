{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-ndd-cli-node.semantic.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.conveyor.ndd-cli.materialize-node",
  "sourceLineage": {
    "storyKey": "stories/cli/ndd-cli.story.v1.json",
    "canonicalSpecKey": "specs/canonical/cli/ndd-cli.canonical-spec.v1.json",
    "projectionManifestKey": "contracts/projections/ndd-cli.node-projection-manifest.v1.json",
    "semanticOperationGraphKey": "contracts/semantic-operation-graphs/cli/ndd-cli.execute.sog.v1.json"
  },
  "bodyDisposition": {
    "bodyKind": "facade_composition_graph",
    "hostLanguageBodyAllowed": false,
    "projectionOnly": true,
    "promotionValidSource": false,
    "regenerable": true,
    "forbiddenBodyForms": [
      "inline_js_blob",
      "inline_python_blob",
      "inline_csharp_blob",
      "dto_stitching",
      "local_business_logic",
      "manual_fallback"
    ]
  },
  "semanticBody": {
    "bodyKind": "facade_composition_graph",
    "bodyRef": "contracts/facade-compositions/cli/ndd-cli.node-resolver-doorway.composition.v1.json",
    "hostLanguageBodyAllowed": false
  },
  "capabilityBindings": {
    "bindingRef": "contracts/capabilities/facade-materialization.capability-bindings.v1.json",
    "missingCapabilityBehavior": "blocked"
  },
  "boundedOutputs": [
    "generated/cli/node/ndd.cjs",
    "evidence/cli/ndd-cli.node-projection.receipt.v1.json"
  ],
  "steps": [
    {
      "id": "resolveProjectionAuthority",
      "type": "resolver",
      "operation": "resolve.contract.v1",
      "payload": {
        "requiredContracts": [
          "stories/cli/ndd-cli.story.v1.json",
          "specs/canonical/cli/ndd-cli.canonical-spec.v1.json",
          "contracts/projections/ndd-cli.node-projection-manifest.v1.json",
          "contracts/sej/ndd-cli.execute.sej.v1.json"
        ]
      }
    },
    {
      "id": "composeFacadeBody",
      "type": "resolver",
      "operation": "facade.compose.v1",
      "payload": {
        "compositionRef": "contracts/facade-compositions/cli/ndd-cli.node-resolver-doorway.composition.v1.json"
      }
    },
    {
      "id": "materializeFacade",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "artifact": {
          "path": "generated/cli/node/ndd.cjs",
          "format": "text",
          "contentRef": "$steps.composeFacadeBody.renderedText"
        }
      }
    },
    {
      "id": "hashFacade",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "path": "generated/cli/node/ndd.cjs"
      }
    },
    {
      "id": "emitReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "receipt": {
          "path": "evidence/cli/ndd-cli.node-projection.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.ndd-cli.node-projection.receipt.v1",
            "status": "passed",
            "projectedPath": "generated/cli/node/ndd.cjs",
            "sourceSej": "contracts/sej/materialize-ndd-cli-node.semantic.sej.v1.json",
            "projectionManifest": "contracts/projections/ndd-cli.node-projection-manifest.v1.json",
            "semanticOperationGraph": "contracts/semantic-operation-graphs/cli/ndd-cli.execute.sog.v1.json",
            "artifactHash": "$steps.hashFacade.hash",
            "bodyDisposition": "generated_thin_resolver_facade"
          }
        }
      }
    }
  ],
  "failurePosture": "fail-closed",
  "completionPosture": "NDD CLI Doorway materialization SEJ contains no JS body; it composes a facade from governed graph references."
}
