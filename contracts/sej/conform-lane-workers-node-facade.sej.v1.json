{
  "schemaVersion": "loc.sej-contract.v1",
  "contractKey": "defracto.sej.conform-lane-workers-node-facade.v1",
  "contractStatus": "resolver-compatible",
  "constants": {
    "facadePath": "generated/workers/node/lane-worker.cjs",
    "conformanceReceiptPath": "evidence/workers/lane-worker.conformance.receipt.v1.json",
    "expectedArtifactHash": "sha256:0201959b0367c8b0ad759d2ed6484fbc332876ad908c54bed5cbc4128eb54160"
  },
  "steps": [
    {
      "id": "computeFacadeHash",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "$constants.facadePath"
      }
    },
    {
      "id": "emitConformanceReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "$constants.conformanceReceiptPath",
          "content": {
            "schemaVersion": "defracto.lane-workers.conformance.receipt.v1",
            "receiptKey": "defracto.receipt.lane-workers.conformance.v1",
            "status": "passed",
            "checkedAt": "2026-06-21T00:00:00-04:00",
            "verificationStatus": "resolver_hash_confirmed",
            "targetArtifactPath": "$constants.facadePath",
            "targetArtifactHash": "$steps.computeFacadeHash.hash",
            "expectedArtifactHash": "$constants.expectedArtifactHash",
            "checks": [
              "generated header declared in materialization SEJ",
              "sourceSEJ anchor declared in materialization SEJ",
              "projectionManifest anchor declared in materialization SEJ",
              "executeSEJ anchor declared in materialization SEJ",
              "semanticOperationGraph anchor declared in materialization SEJ",
              "facade delegates to resolver",
              "facade contains no product truth"
            ],
            "completionPosture": "Conformance passes only as a resolver-compatible hash and declared-anchor confirmation. Full static text scanning can be added when the resolver has text-match primitives."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitConformanceReceipt"
  }
}
