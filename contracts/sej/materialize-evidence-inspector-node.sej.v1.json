{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-evidence-inspector-node.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.conveyor.evidence-inspector.materialize-node",
  "sourceLineage": {
    "storyKey": "stories/inspector/evidence-inspector.story.v1.json",
    "canonicalSpecKey": "specs/canonical/inspector/evidence-inspector.canonical-spec.v1.json",
    "executableProjectionContractKey": "contracts/projections/evidence-inspector.node-projection-manifest.v1.json",
    "semanticOperationGraphKey": "contracts/semantic-operation-graphs/inspector/evidence-inspector.execute.sog.v1.json",
    "bodyDispositionKey": "defracto.body.evidence-inspector.generated-thin-facade"
  },
  "bodyDisposition": {
    "bodyKind": "facade_composition_graph",
    "hostLanguageBodyAllowed": false,
    "compiledBridgeAllowed": false,
    "bootstrapDelegateAllowed": false,
    "promotionValidSource": true,
    "forbiddenBodyForms": [
      "inline_js_blob",
      "dto_stitching",
      "local_conveyor_brain"
    ]
  },
  "semanticBody": {
    "bodyKind": "facade_composition_graph",
    "bodyRef": "contracts/facade-compositions/inspector/evidence-inspector.node-resolver-doorway.composition.v1.json",
    "hostLanguageBodyAllowed": false
  },
  "capabilityBindings": {
    "bindingRef": "contracts/capabilities/facade-materialization.capability-bindings.v1.json",
    "missingCapabilityBehavior": "blocked"
  },
  "boundedOutputs": [
    "generated/inspector/node/evidence-inspector.cjs",
    "evidence/inspector/evidence-inspector.node-projection.receipt.v1.json"
  ],
  "requiredOperations": [
    {
      "operationKey": "facade.compose.v1",
      "purpose": "Compose the thin resolver doorway body from declared composition authority.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "artifact.materialize.v1",
      "purpose": "Write the projected Node facade exactly as declared.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "hash.compute.v1",
      "purpose": "Compute the materialized facade hash from disk.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "evidence.emit.v1",
      "purpose": "Emit node projection receipt for the materialized facade.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    }
  ],
  "stages": [
    {
      "id": "composeFacadeBody",
      "type": "resolver",
      "operation": "facade.compose.v1",
      "payload": {
        "composition": {
          "$inline": "contracts/facade-compositions/inspector/evidence-inspector.node-resolver-doorway.composition.v1.json"
        }
      }
    },
    {
      "id": "materializeFacade",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "generated/inspector/node/evidence-inspector.cjs",
          "format": "text",
          "contentRef": "$steps.composeFacadeBody.renderedText"
        }
      }
    },
    {
      "id": "hashFacade",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "generated/inspector/node/evidence-inspector.cjs"
      }
    },
    {
      "id": "emitReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/inspector/evidence-inspector.node-projection.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.evidence-inspector.node-projection.receipt.v1",
            "receiptKey": "defracto.receipt.evidence-inspector.node-projection.v1",
            "status": "passed",
            "projectionManifestPath": "contracts/projections/evidence-inspector.node-projection-manifest.v1.json",
            "sourceSejPath": "contracts/sej/materialize-evidence-inspector-node.sej.v1.json",
            "semanticSourceSejPath": "contracts/sej/materialize-evidence-inspector-node.semantic.sej.v1.json",
            "executeSejPath": "contracts/sej/evidence-inspector.execute.sej.v1.json",
            "semanticOperationGraphPath": "contracts/semantic-operation-graphs/inspector/evidence-inspector.execute.sog.v1.json",
            "projectedPath": "generated/inspector/node/evidence-inspector.cjs",
            "projectedBodyKind": "generated_thin_resolver_facade",
            "artifactHash": "$steps.hashFacade.hash",
            "expectedArtifactHash": "$steps.composeFacadeBody.contentHash",
            "contentSource": "facade.compose.v1 -> artifact.contentRef",
            "verificationStatus": "resolver_materialized_semantic_facade_composition",
            "forbiddenResponsibilities": [
              "silent repair",
              "artifact invention",
              "shipping",
              "worker output mutation"
            ],
            "completionPosture": "Evidence Inspector facade is a generated thin resolver doorway and owns no product truth."
          }
        }
      }
    }
  ],
  "forbiddenHostBehavior": [
    "hand-author generated facade body",
    "embed product meaning in facade",
    "shape DTOs inside facade",
    "repair worker responses",
    "perform release judgment",
    "bypass resolver"
  ],
  "failurePosture": "fail-closed",
  "return": {
    "type": "step",
    "ref": "$steps.emitReceipt"
  },
  "completionPosture": "This is the mature source authority for resolver-mediated evidence-inspector facade materialization."
}
