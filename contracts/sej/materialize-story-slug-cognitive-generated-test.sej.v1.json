{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-story-slug-cognitive-generated-test.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.user-stories.story-slug.materialize-cognitive-generated-test",
  "sourceLineage": {
    "testIntentKey": "contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
    "projectionManifestKey": "contracts/projections/story-slug.cognitive-node-test-projection-manifest.v1.json",
    "geminiInvocationReceipt": "evidence/workers/story-to-tdd.test-intent.gemini-invocation.receipt.v1.json",
    "hardeningReceipt": "evidence/workers/story-to-tdd.test-intent-hardening.receipt.v1.json"
  },
  "targetArtifact": {
    "artifactKey": "defracto.user-stories.story-slug.cognitive-generated-node-test.v1",
    "artifactPath": "tests/generated/user-stories/story-slug.cognitive.generated.test.js",
    "artifactKind": "generated_node_test",
    "artifactStatus": "future"
  },
  "boundedOutputs": [
    "tests/generated/user-stories/story-slug.cognitive.generated.test.js",
    "evidence/tdd/story-slug.cognitive-generated-test.materialization.receipt.v1.json"
  ],
  "forbiddenBodyForms": [
    "hand_authored_test_code",
    "implementation_code",
    "extra_criteria_invention",
    "resolver_repo_change"
  ],
  "steps": [
    {
      "id": "projectCognitiveGeneratedTestSource",
      "type": "resolver",
      "operation": "project.value.v1",
      "payload": {
        "fields": {
          "testLines": {
            "literal": [
              "// GENERATED BY DEFRACTO SEJ MATERIALIZATION. DO NOT EDIT.",
              "// sourceSEJ: contracts/sej/materialize-story-slug-cognitive-generated-test.sej.v1.json",
              "// testIntent: contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
              "// projectionManifest: contracts/projections/story-slug.cognitive-node-test-projection-manifest.v1.json",
              "// geminiInvocation: evidence/workers/story-to-tdd.test-intent.gemini-invocation.receipt.v1.json",
              "",
              "'use strict';",
              "",
              "const assert = require('node:assert/strict');",
              "const path = require('node:path');",
              "const test = require('node:test');",
              "",
              "const implementationPath = path.resolve(__dirname, '../../../generated/implementations/user-stories/story-slug.cognitive.cjs');",
              "",
              "function loadGeneratedImplementation() {",
              "  return require(implementationPath);",
              "}",
              "",
              "function runSlug(input) {",
              "  const implementation = loadGeneratedImplementation();",
              "  assert.equal(typeof implementation.generateStorySlug, 'function', 'generated implementation must export generateStorySlug');",
              "  return implementation.generateStorySlug(input);",
              "}",
              "",
              "test('story-slug.cognitive.test.lowercase-and-whitespace maps accepted lowercase and whitespace criteria', () => {",
              "  assert.deepEqual(runSlug({ title: 'Story Title' }), { status: 'passed', slugKey: 'story-title' });",
              "});",
              "",
              "test('story-slug.cognitive.test.remove-punctuation maps accepted punctuation criterion', () => {",
              "  assert.deepEqual(runSlug({ title: 'Story: Title!' }), { status: 'passed', slugKey: 'story-title' });",
              "});",
              "",
              "test('story-slug.cognitive.test.collapse-hyphens maps accepted repeated hyphen criterion', () => {",
              "  assert.deepEqual(runSlug({ title: 'Story -- Title' }), { status: 'passed', slugKey: 'story-title' });",
              "});",
              "",
              "test('story-slug.cognitive.test.empty-input-blocked maps exact blocked result shape', () => {",
              "  assert.deepEqual(runSlug({ title: '   ' }), { status: 'blocked', blocker: 'empty_slug_input' });",
              "});"
            ]
          }
        }
      }
    },
    {
      "id": "ensureGeneratedTestDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "path": "tests/generated/user-stories"
      }
    },
    {
      "id": "materializeCognitiveGeneratedTest",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "tests/generated/user-stories/story-slug.cognitive.generated.test.js",
          "format": "text",
          "joinWith": "\n",
          "contentRef": "$steps.projectCognitiveGeneratedTestSource.testLines"
        }
      }
    },
    {
      "id": "hashCognitiveGeneratedTest",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "tests/generated/user-stories/story-slug.cognitive.generated.test.js"
      }
    },
    {
      "id": "emitCognitiveGeneratedTestReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/tdd/story-slug.cognitive-generated-test.materialization.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.generated-test-materialization.receipt.v1",
            "receiptKey": "defracto.receipt.story-slug.cognitive-generated-test.materialization.slice-042.v1",
            "status": "passed",
            "sourceSej": "contracts/sej/materialize-story-slug-cognitive-generated-test.sej.v1.json",
            "testIntent": "contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
            "projectionManifest": "contracts/projections/story-slug.cognitive-node-test-projection-manifest.v1.json",
            "targetPath": "tests/generated/user-stories/story-slug.cognitive.generated.test.js",
            "artifactHash": "$steps.hashCognitiveGeneratedTest.hash",
            "criteriaKeys": [
              "story-slug.lowercase-ascii",
              "story-slug.whitespace-to-hyphen",
              "story-slug.remove-punctuation",
              "story-slug.collapse-hyphens",
              "story-slug.empty-input-blocked"
            ],
            "noHandAuthoredCodeObserved": true,
            "completionPosture": "Cognitive generated test projection materialized from promoted cognitive test intent authority."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitCognitiveGeneratedTestReceipt"
  },
  "failurePosture": "Missing cognitive test intent authority or projection manifest blocks materialization.",
  "completionPosture": "This SEJ materializes the cognitive generated test projection and emits the materialization receipt."
}
