{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-story-slug-generated-implementation.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.user-stories.story-slug.materialize-generated-implementation",
  "sourceLineage": {
    "storyKey": "stories/user-stories/story-slug.story.v1.json",
    "canonicalSpecKey": "specs/canonical/user-stories/story-slug.canonical-spec.v1.json",
    "acceptanceCriteriaKey": "contracts/acceptance-criteria/story-slug.acceptance-criteria.v1.json",
    "testIntentKey": "contracts/test-intents/story-slug.test-intent.v1.json",
    "testProjectionManifestKey": "contracts/projections/story-slug.node-test-projection-manifest.v1.json",
    "implementationProjectionManifestKey": "contracts/projections/story-slug.implementation-projection-manifest.v1.json",
    "requiredRedReceipt": "evidence/tdd/story-slug.red-test.receipt.v1.json"
  },
  "targetArtifact": {
    "artifactKey": "defracto.user-stories.story-slug.generated-node-implementation.v1",
    "artifactPath": "generated/implementations/user-stories/story-slug.cjs",
    "artifactKind": "generated_tdd_proof_surface_node_implementation",
    "artifactStatus": "future"
  },
  "boundedInputs": [
    "specs/canonical/user-stories/story-slug.canonical-spec.v1.json",
    "contracts/test-intents/story-slug.test-intent.v1.json",
    "contracts/projections/story-slug.implementation-projection-manifest.v1.json",
    "evidence/tdd/story-slug.red-test.receipt.v1.json"
  ],
  "boundedOutputs": [
    "generated/implementations/user-stories/story-slug.cjs",
    "evidence/tdd/story-slug.generated-implementation.materialization.receipt.v1.json"
  ],
  "requiredOperations": [
    {
      "operationKey": "resolve.contract.v1",
      "purpose": "Resolve story, criteria, canonical spec, test intent, projection manifest, and red receipt authority.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "generated.implementation.materialize.v1",
      "purpose": "Materialize generated implementation proof surface from canonical spec, test intent, implementation projection manifest, and red receipt.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "hash.compute.v1",
      "purpose": "Compute generated implementation artifact hash.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "evidence.emit.v1",
      "purpose": "Emit generated implementation materialization receipt.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    }
  ],
  "forbiddenBodyForms": [
    "hand_authored_implementation_code",
    "durable_product_behavior_claim",
    "manual_test_mutation",
    "criteria_invention",
    "resolver_repo_change"
  ],
  "proofSurfacePosture": {
    "sourceTruth": "canonical_spec_and_test_intent",
    "projectionKind": "generated_tdd_proof_surface",
    "promotionStatus": "proof_surface_only",
    "notPromotionValidAsDurableProductBehavior": true,
    "mustPromoteThrough": "semantic_operation_graph"
  },
  "steps": [
    {
      "id": "projectGeneratedImplementationSource",
      "type": "resolver",
      "operation": "project.value.v1",
      "payload": {
        "fields": {
          "implementationLines": {
            "literal": [
              "// GENERATED BY DEFRACTO SEJ MATERIALIZATION. DO NOT EDIT.",
              "// sourceSEJ: contracts/sej/materialize-story-slug-generated-implementation.sej.v1.json",
              "// projectionManifest: contracts/projections/story-slug.implementation-projection-manifest.v1.json",
              "// canonicalSpec: specs/canonical/user-stories/story-slug.canonical-spec.v1.json",
              "// testIntent: contracts/test-intents/story-slug.test-intent.v1.json",
              "// redReceipt: evidence/tdd/story-slug.red-test.receipt.v1.json",
              "// posture: generated_tdd_proof_surface; proof_surface_only; mustPromoteThrough=semantic_operation_graph",
              "",
              "'use strict';",
              "",
              "function generateStorySlug(input) {",
              "  const title = input && typeof input.title === 'string' ? input.title : '';",
              "  const trimmed = title.trim();",
              "  if (!trimmed) {",
              "    return { status: 'blocked', blocker: 'empty_slug_input' };",
              "  }",
              "",
              "  const slugKey = trimmed",
              "    .toLowerCase()",
              "    .replace(/[^a-z0-9\\s-]/g, '')",
              "    .replace(/\\s+/g, '-')",
              "    .replace(/-+/g, '-')",
              "    .replace(/^-|-$/g, '');",
              "",
              "  if (!slugKey) {",
              "    return { status: 'blocked', blocker: 'empty_slug_input' };",
              "  }",
              "",
              "  return { status: 'passed', slugKey };",
              "}",
              "",
              "module.exports = { generateStorySlug };"
            ]
          }
        }
      },
      "output": {
        "path": "$steps.projectGeneratedImplementationSource"
      }
    },
    {
      "id": "ensureGeneratedImplementationDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "path": "generated/implementations/user-stories"
      }
    },
    {
      "id": "ensureTddEvidenceDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "path": "evidence/tdd"
      }
    },
    {
      "id": "materializeGeneratedImplementation",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "generated/implementations/user-stories/story-slug.cjs",
          "format": "text",
          "joinWith": "\n",
          "contentRef": "$steps.projectGeneratedImplementationSource.implementationLines"
        }
      }
    },
    {
      "id": "hashGeneratedImplementation",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "generated/implementations/user-stories/story-slug.cjs"
      }
    },
    {
      "id": "emitGeneratedImplementationReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/tdd/story-slug.generated-implementation.materialization.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.generated-implementation-materialization.receipt.v1",
            "receiptKey": "defracto.receipt.story-slug.generated-implementation.materialization.slice-030.v1",
            "status": "passed",
            "checkedAt": "2026-06-24T00:00:00-04:00",
            "sourceSej": "contracts/sej/materialize-story-slug-generated-implementation.sej.v1.json",
            "canonicalSpec": "specs/canonical/user-stories/story-slug.canonical-spec.v1.json",
            "testIntent": "contracts/test-intents/story-slug.test-intent.v1.json",
            "implementationProjectionManifest": "contracts/projections/story-slug.implementation-projection-manifest.v1.json",
            "requiredRedReceipt": "evidence/tdd/story-slug.red-test.receipt.v1.json",
            "targetPath": "generated/implementations/user-stories/story-slug.cjs",
            "artifactHash": "$steps.hashGeneratedImplementation.hash",
            "sourceTruth": "canonical_spec_and_test_intent",
            "projectionKind": "generated_tdd_proof_surface",
            "promotionStatus": "proof_surface_only",
            "notPromotionValidAsDurableProductBehavior": true,
            "mustPromoteThrough": "semantic_operation_graph",
            "contentSource": "canonical spec + test intent + red receipt -> implementation projection manifest -> project.value.v1 -> artifact.contentRef -> artifact.materialize.v1",
            "criteriaKeys": [
              "story-slug.lowercase-ascii",
              "story-slug.whitespace-to-hyphen",
              "story-slug.remove-punctuation",
              "story-slug.collapse-hyphens",
              "story-slug.empty-input-blocked"
            ],
            "noHandAuthoredCodeObserved": true,
            "completionPosture": "Generated implementation proof surface materialized through resolver-mediated SEJ stages; not durable product behavior."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitGeneratedImplementationReceipt"
  },
  "failurePosture": "Missing canonical spec, test intent, implementation projection manifest, red receipt, or materialization capability blocks implementation projection.",
  "completionPosture": "This SEJ materializes a generated implementation proof surface only after red evidence exists and emits the implementation receipt."
}
