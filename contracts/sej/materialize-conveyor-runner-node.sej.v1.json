{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-conveyor-runner-node.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.conveyor.runner.materialize-node",
  "sourceLineage": {
    "executeSej": "contracts/sej/conveyor-runner.execute.sej.v1.json",
    "semanticOperationGraph": "contracts/semantic-operation-graphs/runner/conveyor-runner.execute.sog.v1.json",
    "facadeComposition": "contracts/facade-compositions/runner/conveyor-runner.node-resolver-doorway.composition.v1.json"
  },
  "bodyDisposition": {
    "bodyKind": "facade_composition_graph",
    "hostLanguageBodyAllowed": false,
    "compiledBridgeAllowed": false,
    "bootstrapDelegateAllowed": false,
    "promotionValidSource": true,
    "forbiddenBodyForms": [
      "inline_js_blob",
      "dto_stitching",
      "local_conveyor_brain"
    ]
  },
  "steps": [
    {
      "id": "composeRunnerFacade",
      "type": "resolver",
      "operation": "facade.compose.v1",
      "payload": {
        "composition": {
          "$inline": "contracts/facade-compositions/runner/conveyor-runner.node-resolver-doorway.composition.v1.json"
        }
      }
    },
    {
      "id": "materializeRunnerFacade",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "generated/runner/node/conveyor-runner.cjs",
          "format": "text",
          "contentRef": "$steps.composeRunnerFacade.renderedLines",
          "joinWith": "\n",
          "newline": "lf"
        }
      }
    },
    {
      "id": "hashRunnerFacade",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "generated/runner/node/conveyor-runner.cjs"
      }
    },
    {
      "id": "emitRunnerProjectionReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/runner/conveyor-runner.node-projection.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.conveyor-runner.node-projection.receipt.v1",
            "receiptKey": "defracto.receipt.conveyor-runner.node-projection.v1",
            "status": "passed",
            "sourceSej": "contracts/sej/materialize-conveyor-runner-node.sej.v1.json",
            "executeSej": "contracts/sej/conveyor-runner.execute.sej.v1.json",
            "semanticOperationGraph": "contracts/semantic-operation-graphs/runner/conveyor-runner.execute.sog.v1.json",
            "facadeComposition": "contracts/facade-compositions/runner/conveyor-runner.node-resolver-doorway.composition.v1.json",
            "projectedPath": "generated/runner/node/conveyor-runner.cjs",
            "artifactHash": "$steps.hashRunnerFacade.hash",
            "expectedArtifactHash": "$steps.composeRunnerFacade.contentHash",
            "contentSource": "facade.compose.v1 -> artifact.contentRef",
            "forbiddenResponsibilities": [
              "runner brain",
              "DTO shaping",
              "stage policy invention",
              "compiled bridge fallback",
              "bootstrap delegate"
            ],
            "completionPosture": "Generated runner facade is a disposable resolver doorway. Conveyor run behavior is in SEJ/SOG."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitRunnerProjectionReceipt"
  }
}
