            "  } catch (error) {",
            "    fail(`Missing resolver package ${RESOLVER_PACKAGE}: ${error.message || String(error)}`, 2);",
            "  }",
            "}",
            "",
            "async function invokeResolver(argv, payload) {",
            "  const resolver = loadResolver();",
            "  const contractPath = path.resolve(process.cwd(), EXECUTE_SEJ_PATH);",
            "",
            "  if (!fs.existsSync(contractPath)) {",
