            "    argv,",
            "    payload,",
            "    failClosed: true",
            "  };",
            "",
            "  if (typeof resolver.resolveContract === 'function') {",
            "    return resolver.resolveContract(invocation);",
            "  }",
            "",
            "  if (typeof resolver.resolve === 'function') {",
            "    return resolver.resolve(invocation);",
            "  }",
            "",
            "  fail('Resolver does not expose resolveContract or resolve.', 5);",
            "}",
            "",
            "async function main(argv = process.argv.slice(2)) {",
