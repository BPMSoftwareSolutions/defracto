{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-lane-workers-node.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.conveyor.lane-workers.materialize-node",
  "purpose": "Active lane-worker facade materialization authority without embedded JS body content.",
  "semanticBody": {
    "bodyKind": "facade_composition_graph",
    "bodyRef": "contracts/facade-compositions/workers/lane-workers.node-resolver-doorway.composition.v1.json",
    "hostLanguageBodyAllowed": false
  },
  "requiresResolverCapabilities": [
    "facade.compose.v1",
    "artifact.contentRef"
  ],
  "boundedOutputs": [
    "generated/workers/node/lane-worker.cjs",
    "evidence/workers/lane-worker.node-projection.receipt.v1.json"
  ],
  "steps": [
    {
      "id": "composeFacadeBody",
      "type": "resolver",
      "operation": "facade.compose.v1",
      "payload": {
        "composition": {
          "$inline": "contracts/facade-compositions/workers/lane-workers.node-resolver-doorway.composition.v1.json"
        }
      }
    },
    {
      "id": "materializeFacade",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "generated/workers/node/lane-worker.cjs",
          "format": "text",
          "contentRef": "$steps.composeFacadeBody.renderedLines",
          "joinWith": "\n"
        }
      }
    },
    {
      "id": "hashFacade",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "generated/workers/node/lane-worker.cjs"
      }
    },
    {
      "id": "emitReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/workers/lane-worker.node-projection.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.lane-workers.node-projection.receipt.v1",
            "receiptKey": "defracto.receipt.lane-workers.node-projection.v1",
            "status": "passed",
            "checkedAt": "2026-06-21T00:00:00-04:00",
            "verificationStatus": "resolver_materialized_semantic_facade_composition",
            "sourceSej": "contracts/sej/materialize-lane-workers-node.sej.v1.json",
            "semanticSourceSej": "contracts/sej/materialize-lane-workers-node.semantic.sej.v1.json",
            "projectionManifest": "contracts/projections/lane-workers.node-projection-manifest.v1.json",
            "executeSej": "contracts/sej/lane-workers.execute.sej.v1.json",
            "semanticOperationGraph": "contracts/semantic-operation-graphs/workers/lane-workers.execute.sog.v1.json",
            "projectedPath": "generated/workers/node/lane-worker.cjs",
            "artifactHash": "$steps.hashFacade.hash",
            "bodyDisposition": "generated_thin_resolver_facade",
            "completionPosture": "The generated worker facade is materialized from facade.compose.v1 and contentRef. Semantic behavior remains in the semantic operation graph."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitReceipt"
  },
  "completionPosture": "This is the mature source authority for resolver-mediated lane-worker facade materialization."
}
