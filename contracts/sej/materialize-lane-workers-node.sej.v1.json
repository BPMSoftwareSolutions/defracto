            "",
            "if (require.main === module) {",
            "  main().catch(error => {",
            "    fail(error && error.message ? error.message : String(error), 1);",
            "  });",
            "}",
            "",
            "module.exports = {",
            "  main,",
            "  invokeResolver",
            "};"
