{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-story-slug-generated-test.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.user-stories.story-slug.materialize-generated-test",
  "sourceLineage": {
    "storyKey": "stories/user-stories/story-slug.story.v1.json",
    "canonicalSpecKey": "specs/canonical/user-stories/story-slug.canonical-spec.v1.json",
    "acceptanceCriteriaKey": "contracts/acceptance-criteria/story-slug.acceptance-criteria.v1.json",
    "testIntentKey": "contracts/test-intents/story-slug.test-intent.v1.json",
    "projectionManifestKey": "contracts/projections/story-slug.node-test-projection-manifest.v1.json"
  },
  "targetArtifact": {
    "artifactKey": "defracto.user-stories.story-slug.generated-node-test.v1",
    "artifactPath": "tests/generated/user-stories/story-slug.generated.test.js",
    "artifactKind": "generated_node_test",
    "artifactStatus": "future"
  },
  "boundedInputs": [
    "contracts/test-intents/story-slug.test-intent.v1.json",
    "contracts/projections/story-slug.node-test-projection-manifest.v1.json"
  ],
  "boundedOutputs": [
    "tests/generated/user-stories/story-slug.generated.test.js",
    "evidence/tdd/story-slug.generated-test.materialization.receipt.v1.json"
  ],
  "requiredOperations": [
    {
      "operationKey": "resolve.contract.v1",
      "purpose": "Resolve story, criteria, canonical spec, test intent, and projection manifest authority.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "generated.test.materialize.v1",
      "purpose": "Materialize generated test artifact from accepted test intent and projection manifest without hand-authored test source.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "hash.compute.v1",
      "purpose": "Compute generated test artifact hash.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "evidence.emit.v1",
      "purpose": "Emit generated test materialization receipt.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    }
  ],
  "forbiddenBodyForms": [
    "inline_js_blob",
    "hand_authored_test_code",
    "manual_test_fixture",
    "implementation_code",
    "resolver_repo_change"
  ],
  "steps": [
    {
      "id": "projectGeneratedTestSource",
      "type": "resolver",
      "operation": "project.value.v1",
      "payload": {
        "fields": {
          "testLines": {
            "literal": [
              "// GENERATED BY DEFRACTO SEJ MATERIALIZATION. DO NOT EDIT.",
              "// sourceSEJ: contracts/sej/materialize-story-slug-generated-test.sej.v1.json",
              "// projectionManifest: contracts/projections/story-slug.node-test-projection-manifest.v1.json",
              "// testIntent: contracts/test-intents/story-slug.test-intent.v1.json",
              "// criteria: story-slug.lowercase-ascii, story-slug.whitespace-to-hyphen, story-slug.remove-punctuation, story-slug.collapse-hyphens, story-slug.empty-input-blocked",
              "",
              "'use strict';",
              "",
              "const assert = require('node:assert/strict');",
              "const path = require('node:path');",
              "const test = require('node:test');",
              "",
              "const implementationPath = path.resolve(__dirname, '../../../generated/implementations/user-stories/story-slug.cjs');",
              "",
              "function loadGeneratedImplementation() {",
              "  return require(implementationPath);",
              "}",
              "",
              "function runSlug(input) {",
              "  const implementation = loadGeneratedImplementation();",
              "  assert.equal(typeof implementation.generateStorySlug, 'function', 'generated implementation must export generateStorySlug');",
              "  return implementation.generateStorySlug(input);",
              "}",
              "",
              "test('story-slug.test.lowercase-and-whitespace covers lowercase ASCII and whitespace replacement', () => {",
              "  assert.deepEqual(runSlug({ title: 'Story Title' }), { status: 'passed', slugKey: 'story-title' });",
              "});",
              "",
              "test('story-slug.test.remove-punctuation covers unsupported punctuation removal', () => {",
              "  assert.deepEqual(runSlug({ title: 'Story: Title!' }), { status: 'passed', slugKey: 'story-title' });",
              "});",
              "",
              "test('story-slug.test.collapse-hyphens covers repeated hyphen collapse', () => {",
              "  assert.deepEqual(runSlug({ title: 'Story -- Title' }), { status: 'passed', slugKey: 'story-title' });",
              "});",
              "",
              "test('story-slug.test.empty-input-blocked covers exact empty input blocker', () => {",
              "  assert.deepEqual(runSlug({ title: '   ' }), { status: 'blocked', blocker: 'empty_slug_input' });",
              "});"
            ]
          }
        }
      },
      "output": {
        "path": "$steps.projectGeneratedTestSource"
      }
    },
    {
      "id": "ensureGeneratedTestDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "path": "tests/generated/user-stories"
      }
    },
    {
      "id": "ensureTddEvidenceDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "path": "evidence/tdd"
      }
    },
    {
      "id": "materializeGeneratedTest",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "tests/generated/user-stories/story-slug.generated.test.js",
          "format": "text",
          "joinWith": "\n",
          "contentRef": "$steps.projectGeneratedTestSource.testLines"
        }
      }
    },
    {
      "id": "hashGeneratedTest",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "tests/generated/user-stories/story-slug.generated.test.js"
      }
    },
    {
      "id": "emitGeneratedTestReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/tdd/story-slug.generated-test.materialization.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.generated-test-materialization.receipt.v1",
            "receiptKey": "defracto.receipt.story-slug.generated-test.materialization.slice-029.v1",
            "status": "passed",
            "checkedAt": "2026-06-24T00:00:00-04:00",
            "sourceSej": "contracts/sej/materialize-story-slug-generated-test.sej.v1.json",
            "testIntent": "contracts/test-intents/story-slug.test-intent.v1.json",
            "projectionManifest": "contracts/projections/story-slug.node-test-projection-manifest.v1.json",
            "targetPath": "tests/generated/user-stories/story-slug.generated.test.js",
            "artifactHash": "$steps.hashGeneratedTest.hash",
            "contentSource": "test intent -> projection manifest -> project.value.v1 -> artifact.contentRef -> artifact.materialize.v1",
            "criteriaKeys": [
              "story-slug.lowercase-ascii",
              "story-slug.whitespace-to-hyphen",
              "story-slug.remove-punctuation",
              "story-slug.collapse-hyphens",
              "story-slug.empty-input-blocked"
            ],
            "excludedFromNodeTestRunner": [
              {
                "criteriaKey": "story-slug.no-hand-authored-code",
                "reason": "Verified by projection manifest, materialization receipt, and no-hand-authored-code gate rather than unit assertion."
              }
            ],
            "noHandAuthoredCodeObserved": true,
            "completionPosture": "Generated test projection materialized through resolver-mediated SEJ stages."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitGeneratedTestReceipt"
  },
  "failurePosture": "Missing test projection capability or missing authority blocks materialization.",
  "completionPosture": "This SEJ materializes the generated test projection through declared resolver stages and emits the generated test receipt."
}
