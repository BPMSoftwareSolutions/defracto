    {
      "id": "materializeKernel",
      "type": "primitive",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "kernel.materialization"
        },
        "artifact": {
          "path": "kernels/ascii-render-kernel/ascii-render-kernel.js",
          "format": "text",
          "anchor": {
            "enabled": true,
            "sourceSej": "contracts/sej/materialize-ascii-render-kernel-node.sej.v1.json",
            "contractKey": "defracto.sej.materialize-ascii-render-kernel-node.v1",
            "commentPrefix": "//"
          },
          "content": [
            "// Generated kernel for defracto.kernels.ascii_render_kernel.",
            "// This file is resolver-materialized and owns no visual truth.",
            "",
            "'use strict';",
            "",
            "const crypto = require('node:crypto');",
            "",
            "const KERNEL_VERSION = 'ascii-render-kernel.v1';",
            "const ALLOWED_CONNECTOR = 'vertical-arrow';",
            "",
            "function isObject(value) {",
            "  return value !== null && typeof value === 'object' && !Array.isArray(value);",
            "}",
            "",
            "function makeError(message, details) {",
            "  const error = new Error(message);",
            "  error.details = details || {};",
            "  return error;",
            "}",
            "",
            "function assert(condition, message, details) {",
            "  if (!condition) {",
            "    throw makeError(message, details);",
            "  }",
            "}",
            "",
            "function stableStringify(value) {",
            "  if (Array.isArray(value)) {",
            "    return `[${value.map((item) => stableStringify(item)).join(',')}]`;",
            "  }",
            "  if (isObject(value)) {",
            "    const entries = Object.keys(value)",
            "      .sort()",
            "      .map((key) => `${JSON.stringify(key)}:${stableStringify(value[key])}`);",
            "    return `{${entries.join(',')}}`;",
            "  }",
            "  return JSON.stringify(value);",
            "}",
            "",
            "function hashText(text) {",
            "  return crypto.createHash('sha256').update(text, 'utf8').digest('hex');",
            "}",
            "",
            "function centerText(text, width) {",
            "  assert(text.length <= width, 'text cannot exceed box width', { text, width });",
            "  const remaining = width - text.length;",
            "  const leftPad = Math.floor(remaining / 2);",
            "  const rightPad = remaining - leftPad;",
            "  return `${' '.repeat(leftPad)}${text}${' '.repeat(rightPad)}`;",
            "}",
            "",
            "function createCanvas(width, height) {",
            "  return Array.from({ length: height }, () => Array(width).fill(' '));",
            "}",
            "",
            "function writeChar(canvas, lineIndex, charIndex, char, reason) {",
            "  assert(lineIndex >= 0 && lineIndex < canvas.length, 'render line index out of bounds', { lineIndex, reason });",
            "  assert(charIndex >= 0 && charIndex < canvas[lineIndex].length, 'render column index out of bounds', { lineIndex, charIndex, reason });",
            "  const current = canvas[lineIndex][charIndex];",
            "  if (current !== ' ' && current !== char) {",
            "    throw makeError('render overlap detected', { lineIndex, charIndex, current, next: char, reason });",
            "  }",
            "  canvas[lineIndex][charIndex] = char;",
            "}",
            "",
            "function writeText(canvas, lineIndex, charIndex, text, reason) {",
            "  for (let offset = 0; offset < text.length; offset += 1) {",
            "    writeChar(canvas, lineIndex, charIndex + offset, text[offset], reason);",
            "  }",
            "}",
            "",
            "function sortNodes(nodes) {",
            "  return [...nodes].sort((left, right) => {",
            "    if (left.row !== right.row) return left.row - right.row;",
            "    if (left.column !== right.column) return left.column - right.column;",
            "    return left.nodeKey.localeCompare(right.nodeKey);",
            "  });",
            "}",
            "",
            "function validateModel(model) {",
            "  assert(isObject(model), 'visualProjectionModel must be an object');",
            "  assert(model.modelKind === 'visual-projection-model', 'visualProjectionModel.modelKind must be visual-projection-model');",
            "  assert(Array.isArray(model.layoutRules) && model.layoutRules.length > 0, 'visualProjectionModel.layoutRules must be a non-empty array');",
            "  assert(Array.isArray(model.nodes) && model.nodes.length > 0, 'visualProjectionModel.nodes must be a non-empty array');",
            "  assert(Array.isArray(model.edges), 'visualProjectionModel.edges must be an array');",
            "  assert(Array.isArray(model.surfaces), 'visualProjectionModel.surfaces must be an array');",
            "  assert(Array.isArray(model.regions), 'visualProjectionModel.regions must be an array');",
            "  assert(Array.isArray(model.containers), 'visualProjectionModel.containers must be an array');",
            "  assert(Array.isArray(model.lanes), 'visualProjectionModel.lanes must be an array');",
            "  assert(Array.isArray(model.renderAdapters), 'visualProjectionModel.renderAdapters must be an array');",
            "  assert(Array.isArray(model.equivalenceRules), 'visualProjectionModel.equivalenceRules must be an array');",
            "  assert(Array.isArray(model.forbiddenClaims), 'visualProjectionModel.forbiddenClaims must be an array');",
            "",
            "  const layout = model.layoutRules[0];",
            "  assert(isObject(layout), 'visualProjectionModel.layoutRules[0] must be an object');",
            "  assert(layout.layoutKind === 'visual-layout', 'visualProjectionModel.layoutRules[0].layoutKind must be visual-layout');",
            "  assert(isObject(layout.canvas), 'visualProjectionModel.layoutRules[0].canvas must be an object');",
            "  assert(Array.isArray(layout.nodeOrder) && layout.nodeOrder.length > 0, 'visualProjectionModel.layoutRules[0].nodeOrder must be a non-empty array');",
            "  assert(Array.isArray(layout.connectorRules), 'visualProjectionModel.layoutRules[0].connectorRules must be an array');",
            "  assert(Array.isArray(layout.forbiddenLayoutInvention), 'visualProjectionModel.layoutRules[0].forbiddenLayoutInvention must be an array');",
            "",
            "  const { canvas } = layout;",
            "  assert(Number.isInteger(canvas.widthColumns) && canvas.widthColumns > 0, 'visualProjectionModel.canvas.widthColumns must be a positive integer');",
            "  assert(Number.isInteger(canvas.heightLines) && canvas.heightLines > 0, 'visualProjectionModel.canvas.heightLines must be a positive integer');",
            "  assert(canvas.fontFamily === 'monospace', 'visualProjectionModel.canvas.fontFamily must be monospace');",
            "  assert(canvas.lineWrapping === 'forbidden', 'visualProjectionModel.canvas.lineWrapping must be forbidden');",
            "",
            "  const nodeKeys = new Set();",
            "  const nodeMap = new Map();",
            "  for (const node of model.nodes) {",
            "    assert(isObject(node), 'each visual node must be an object');",
            "    assert(typeof node.nodeKey === 'string' && node.nodeKey.length > 0, 'visual node.nodeKey must be a non-empty string');",
            "    assert(typeof node.label === 'string' && node.label.length > 0, 'visual node.label must be a non-empty string');",
            "    assert(typeof node.artifactPath === 'string' && node.artifactPath.length > 0, 'visual node.artifactPath must be a non-empty string');",
            "    assert(typeof node.semanticRole === 'string' && node.semanticRole.length > 0, 'visual node.semanticRole must be a non-empty string');",
            "    assert(Number.isInteger(node.row) && node.row > 0, 'visual node.row must be a positive integer');",
            "    assert(Number.isInteger(node.column) && node.column >= 0, 'visual node.column must be a non-negative integer');",
            "    assert(Number.isInteger(node.width) && node.width >= 4, 'visual node.width must be an integer >= 4');",
            "    assert(Number.isInteger(node.height) && node.height === 3, 'visual node.height must be exactly 3 for the conveyor sketch');",
            "    assert(node.label.length <= node.width - 2, 'visual node.label must fit within the node width', { nodeKey: node.nodeKey });",
            "    assert(!nodeKeys.has(node.nodeKey), 'visualProjectionModel.nodes must not contain duplicate node keys', { nodeKey: node.nodeKey });",
            "    nodeKeys.add(node.nodeKey);",
            "    nodeMap.set(node.nodeKey, node);",
            "  }",
            "",
            "  const sortedNodes = sortNodes(model.nodes);",
            "  const layoutNodeOrder = [...layout.nodeOrder];",
            "  assert(layoutNodeOrder.length === sortedNodes.length, 'layout node order must match the node count');",
            "  assert(layoutNodeOrder.every((nodeKey, index) => nodeKey === sortedNodes[index].nodeKey), 'layout node order must match the rendered node order');",
            "",
            "  for (const edge of model.edges) {",
            "    assert(isObject(edge), 'each visual edge must be an object');",
            "    assert(typeof edge.edgeKey === 'string' && edge.edgeKey.length > 0, 'visual edge.edgeKey must be a non-empty string');",
            "    assert(nodeKeys.has(edge.fromNodeKey), 'visual edge fromNodeKey must reference an existing node', { edgeKey: edge.edgeKey });",
            "    assert(nodeKeys.has(edge.toNodeKey), 'visual edge toNodeKey must reference an existing node', { edgeKey: edge.edgeKey });",
            "    assert(edge.connector === ALLOWED_CONNECTOR, 'unsupported connector type', { edgeKey: edge.edgeKey, connector: edge.connector });",
            "  }",
            "",
            "  for (const binding of model.semanticBindings) {",
            "    assert(isObject(binding), 'each semantic binding must be an object');",
            "    assert(typeof binding.targetNodeKey === 'string' && nodeKeys.has(binding.targetNodeKey), 'semantic binding targetNodeKey must reference an existing node');",
            "  }",
            "",
            "  return { layout, nodeMap, sortedNodes };",
            "}",
            "",
            "function renderBoxNode(canvas, node) {",
            "  const topLine = node.row - 1;",
            "  const labelLine = topLine + 1;",
            "  const bottomLine = topLine + 2;",
            "  const left = node.column;",
            "  const width = node.width;",
            "  const innerWidth = width - 2;",
            "  const centerColumn = left + Math.floor(width / 2);",
            "",
            "  assert(left + width <= canvas[0].length, 'node exceeds canvas width', { nodeKey: node.nodeKey });",
            "  assert(bottomLine < canvas.length, 'node exceeds canvas height', { nodeKey: node.nodeKey });",
            "",
            "  writeText(canvas, topLine, left, `+${'-'.repeat(innerWidth)}+`, `node top border: ${node.nodeKey}`);",
            "  writeText(canvas, labelLine, left, `|${centerText(node.label, innerWidth)}|`, `node label: ${node.nodeKey}`);",
            "  writeText(canvas, bottomLine, left, `+${'-'.repeat(innerWidth)}+`, `node bottom border: ${node.nodeKey}`);",
            "",
            "  return { centerColumn, bottomLine };",
            "}",
            "",
            "function renderEdge(canvas, sourceNode, targetNode, edge) {",
            "  assert(edge.connector === ALLOWED_CONNECTOR, 'unsupported connector type', { edgeKey: edge.edgeKey, connector: edge.connector });",
            "  assert(sourceNode.column === targetNode.column, 'kernel conveyor must remain in a single visual column', { edgeKey: edge.edgeKey });",
            "",
            "  const sourceBottomLine = sourceNode.row + 1;",
            "  const targetTopLine = targetNode.row - 1;",
            "  const arrowLine = targetTopLine - 1;",
            "  const centerColumn = sourceNode.column + Math.floor(sourceNode.width / 2);",
            "",
            "  assert(arrowLine > sourceBottomLine, 'edge must have room between nodes', { edgeKey: edge.edgeKey });",
            "  assert(arrowLine < canvas.length, 'edge exceeds canvas height', { edgeKey: edge.edgeKey });",
            "",
            "  for (let line = sourceBottomLine + 1; line < arrowLine; line += 1) {",
            "    writeChar(canvas, line, centerColumn, '|', `connector stem: ${edge.edgeKey}`);",
            "  }",
            "  writeChar(canvas, arrowLine, centerColumn, 'v', `connector arrowhead: ${edge.edgeKey}`);",
            "}",
            "",
            "function renderAsciiProjection(model, options = {}) {",
            "  const { layout, nodeMap, sortedNodes } = validateModel(model);",
            "  const canvasWidth = layout.canvas.widthColumns;",
            "  const canvasHeight = layout.canvas.heightLines;",
            "  const canvas = createCanvas(canvasWidth, canvasHeight);",
            "",
            "  for (const node of sortedNodes) {",
            "    renderBoxNode(canvas, node);",
            "  }",
            "",
            "  for (const edge of model.edges) {",
            "    const sourceNode = nodeMap.get(edge.fromNodeKey);",
            "    const targetNode = nodeMap.get(edge.toNodeKey);",
            "    renderEdge(canvas, sourceNode, targetNode, edge);",
            "  }",
            "",
            "  const renderedLines = canvas.map((line) => line.join('').replace(/\\s+$/u, ''));",
            "  const renderedText = renderedLines.join('\\n');",
            "  const targetArtifactPath = options.targetArtifactPath || (model.targetSketches[0] && model.targetSketches[0].targetSketchPath) || '';",
            "  const visualProjectionModelPath = options.visualProjectionModelPath || '';",
            "",
            "  assert(targetArtifactPath.length > 0, 'targetArtifactPath must be supplied for the projected kernel', { modelKey: model.modelKey });",
            "  assert(visualProjectionModelPath.length > 0, 'visualProjectionModelPath must be supplied for the projected kernel', { modelKey: model.modelKey });",
            "",
            "  return {",
            "    schemaVersion: 'defracto.ascii-render-result.v1',",
            "    resultKey: options.resultKey || `defracto.ascii-render-result.${model.modelKey}.v1`,",
            "    resultKind: 'ascii-render-result',",
            "    resultStatus: 'accepted',",
            "    visualProjectionModelKey: model.modelKey,",
            "    visualProjectionModelPath,",
            "    targetArtifactPath,",
            "    renderedText,",
            "    renderedLines,",
            "    lineCount: renderedLines.length,",
            "    characterCount: renderedText.length,",
            "    contentHash: hashText(renderedText),",
            "    blockingReasons: [],",
            "    warnings: [],",
            "    completionPosture: 'Deterministic ASCII rendering completed from governed visualProjectionModel input.'",
            "  };",
            "}",
            "",
            "module.exports = {",
            "  KERNEL_VERSION,",
            "  renderAsciiProjection,",
            "  validateModel,",
            "  stableStringify,",
            "  hashText",
            "};"
          ],
          "joinWith": "\n"
        }
      }
