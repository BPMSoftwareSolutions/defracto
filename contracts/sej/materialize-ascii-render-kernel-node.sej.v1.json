              "",
              "function fail(message, code = 1) {",
              "  console.error(`${process.argv[1]}: ${message}`);",
              "  process.exit(code);",
              "}",
              "",
              "function readStdin() {",
              "  return new Promise((resolve, reject) => {",
              "    let data = \"\";",
              "    process.stdin.setEncoding('utf8');",
              "    process.stdin.on('data', (chunk) => { data += chunk; });",
              "    process.stdin.on('end', () => resolve(data));",
              "    process.stdin.on('error', reject);",
              "  });",
              "}",
              "",
              "async function main() {",
              "  const doorway = require('@bpmsoftwaresolutions/sej-resolver-node/doorway');",
              "  const stdin = process.stdin.isTTY ? \"\" : await readStdin();",
              "  const result = await doorway.run({",
              "    toolKey: \"defracto.kernels.ascii_render_kernel\",",
              "    sourceSej: \"contracts/sej/ascii-render-kernel.semantic-kernel.v1.json\",",
              "    argv: process.argv.slice(2),",
              "    stdin",
              "  });",
              "  if (result && result.status && result.status !== \"passed\") {",
              "    process.exit(1);",
              "  }",
              "}",
              "",
