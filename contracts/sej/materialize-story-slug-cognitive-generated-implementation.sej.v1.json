{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.materialize-story-slug-cognitive-generated-implementation.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.user-stories.story-slug.materialize-cognitive-generated-implementation",
  "sourceLineage": {
    "storyAuthorityPromotionReceipt": "evidence/cli/ndd-story-plan.authority-promotion.receipt.v2.json",
    "testIntentKey": "contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
    "testProjectionManifestKey": "contracts/projections/story-slug.cognitive-node-test-projection-manifest.v1.json",
    "implementationProjectionManifestKey": "contracts/projections/story-slug.cognitive-implementation-projection-manifest.v1.json",
    "requiredRedReceipt": "evidence/tdd/story-slug.cognitive-red-test.receipt.v1.json",
    "primaryProviderFailureReceipt": "evidence/workers/story-to-tdd.implementation.gemini-invocation.receipt.v1.json",
    "providerFallbackReceipt": "evidence/workers/story-to-tdd.provider-fallback.receipt.v1.json",
    "openaiInvocationReceipt": "evidence/workers/story-to-tdd.openai-invocation.receipt.v1.json",
    "openaiHardeningReceipt": "evidence/workers/story-to-tdd.openai-implementation-hardening.receipt.v1.json"
  },
  "targetArtifact": {
    "artifactKey": "defracto.user-stories.story-slug.cognitive-generated-node-implementation.v1",
    "artifactPath": "generated/implementations/user-stories/story-slug.cognitive.cjs",
    "artifactKind": "generated_tdd_proof_surface_node_implementation",
    "artifactStatus": "future"
  },
  "boundedInputs": [
    "contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
    "contracts/projections/story-slug.cognitive-implementation-projection-manifest.v1.json",
    "evidence/tdd/story-slug.cognitive-red-test.receipt.v1.json",
    "evidence/workers/story-to-tdd.provider-fallback.receipt.v1.json",
    "evidence/workers/story-to-tdd.openai-implementation-hardening.receipt.v1.json"
  ],
  "boundedOutputs": [
    "generated/implementations/user-stories/story-slug.cognitive.cjs",
    "evidence/tdd/story-slug.cognitive-generated-implementation.materialization.receipt.v1.json"
  ],
  "requiredOperations": [
    {
      "operationKey": "resolve.contract.v1",
      "purpose": "Resolve cognitive test intent, implementation projection manifest, red receipt, provider fallback receipt, and hardening receipt authority.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "generated.implementation.materialize.v1",
      "purpose": "Materialize generated implementation proof surface from accepted fallback projection authority.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "hash.compute.v1",
      "purpose": "Compute generated cognitive implementation artifact hash.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "evidence.emit.v1",
      "purpose": "Emit generated cognitive implementation materialization receipt.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    }
  ],
  "forbiddenBodyForms": [
    "hand_authored_implementation_code",
    "durable_product_behavior_claim",
    "manual_test_mutation",
    "criteria_invention",
    "resolver_repo_change",
    "provider_candidate_as_durable_truth"
  ],
  "proofSurfacePosture": {
    "sourceTruth": "promoted_story_authority_test_intent_red_receipt_and_accepted_provider_candidate",
    "projectionKind": "generated_tdd_proof_surface",
    "promotionStatus": "proof_surface_only",
    "notPromotionValidAsDurableProductBehavior": true,
    "mustPromoteThrough": "semantic_operation_graph"
  },
  "steps": [
    {
      "id": "projectCognitiveGeneratedImplementationSource",
      "type": "resolver",
      "operation": "project.value.v1",
      "payload": {
        "fields": {
          "implementationLines": {
            "literal": [
              "// GENERATED BY DEFRACTO SEJ MATERIALIZATION. DO NOT EDIT.",
              "// sourceSEJ: contracts/sej/materialize-story-slug-cognitive-generated-implementation.sej.v1.json",
              "// projectionManifest: contracts/projections/story-slug.cognitive-implementation-projection-manifest.v1.json",
              "// testIntent: contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
              "// redReceipt: evidence/tdd/story-slug.cognitive-red-test.receipt.v1.json",
              "// primaryProviderFailure: evidence/workers/story-to-tdd.implementation.gemini-invocation.receipt.v1.json",
              "// providerFallback: evidence/workers/story-to-tdd.provider-fallback.receipt.v1.json",
              "// openaiInvocation: evidence/workers/story-to-tdd.openai-invocation.receipt.v1.json",
              "// openaiHardening: evidence/workers/story-to-tdd.openai-implementation-hardening.receipt.v1.json",
              "// posture: generated_tdd_proof_surface; proof_surface_only; mustPromoteThrough=semantic_operation_graph",
              "",
              "'use strict';",
              "",
              "function generateStorySlug(input) {",
              "  const title = input && typeof input.title === 'string' ? input.title : '';",
              "  const trimmed = title.trim();",
              "  if (!trimmed) {",
              "    return { status: 'blocked', blocker: 'empty_slug_input' };",
              "  }",
              "",
              "  const slugKey = trimmed",
              "    .toLowerCase()",
              "    .replace(/[^a-z0-9\\s-]/g, '')",
              "    .replace(/\\s+/g, '-')",
              "    .replace(/-+/g, '-')",
              "    .replace(/^-|-$/g, '');",
              "",
              "  if (!slugKey) {",
              "    return { status: 'blocked', blocker: 'empty_slug_input' };",
              "  }",
              "",
              "  return { status: 'passed', slugKey };",
              "}",
              "",
              "module.exports = { generateStorySlug };"
            ]
          }
        }
      },
      "output": {
        "path": "$steps.projectCognitiveGeneratedImplementationSource"
      }
    },
    {
      "id": "ensureGeneratedImplementationDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "path": "generated/implementations/user-stories"
      }
    },
    {
      "id": "ensureTddEvidenceDirectory",
      "type": "resolver",
      "operation": "filesystem.ensure_directory.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "path": "evidence/tdd"
      }
    },
    {
      "id": "materializeCognitiveGeneratedImplementation",
      "type": "resolver",
      "operation": "artifact.materialize.v1",
      "payload": {
        "authority": {
          "scope": "generated_surface_write_only"
        },
        "artifact": {
          "path": "generated/implementations/user-stories/story-slug.cognitive.cjs",
          "format": "text",
          "joinWith": "\n",
          "contentRef": "$steps.projectCognitiveGeneratedImplementationSource.implementationLines"
        }
      }
    },
    {
      "id": "hashCognitiveGeneratedImplementation",
      "type": "resolver",
      "operation": "hash.compute.v1",
      "payload": {
        "algorithm": "sha256",
        "path": "generated/implementations/user-stories/story-slug.cognitive.cjs"
      }
    },
    {
      "id": "emitCognitiveGeneratedImplementationReceipt",
      "type": "resolver",
      "operation": "evidence.emit.v1",
      "payload": {
        "authority": {
          "scope": "evidence_write_only"
        },
        "receipt": {
          "path": "evidence/tdd/story-slug.cognitive-generated-implementation.materialization.receipt.v1.json",
          "content": {
            "schemaVersion": "defracto.generated-implementation-materialization.receipt.v1",
            "receiptKey": "defracto.receipt.story-slug.cognitive-generated-implementation.materialization.slice-047.v1",
            "status": "passed",
            "sourceSej": "contracts/sej/materialize-story-slug-cognitive-generated-implementation.sej.v1.json",
            "testIntent": "contracts/test-intents/story-slug.cognitive-test-intent.v1.json",
            "implementationProjectionManifest": "contracts/projections/story-slug.cognitive-implementation-projection-manifest.v1.json",
            "requiredRedReceipt": "evidence/tdd/story-slug.cognitive-red-test.receipt.v1.json",
            "primaryProviderFailureReceipt": "evidence/workers/story-to-tdd.implementation.gemini-invocation.receipt.v1.json",
            "providerFallbackReceipt": "evidence/workers/story-to-tdd.provider-fallback.receipt.v1.json",
            "openaiInvocationReceipt": "evidence/workers/story-to-tdd.openai-invocation.receipt.v1.json",
            "openaiHardeningReceipt": "evidence/workers/story-to-tdd.openai-implementation-hardening.receipt.v1.json",
            "targetPath": "generated/implementations/user-stories/story-slug.cognitive.cjs",
            "artifactHash": "$steps.hashCognitiveGeneratedImplementation.hash",
            "sourceTruth": "promoted_story_authority_test_intent_red_receipt_and_accepted_provider_candidate",
            "projectionKind": "generated_tdd_proof_surface",
            "promotionStatus": "proof_surface_only",
            "notPromotionValidAsDurableProductBehavior": true,
            "mustPromoteThrough": "semantic_operation_graph",
            "contentSource": "accepted OpenAI fallback candidate + cognitive test intent + red receipt -> implementation projection manifest -> project.value.v1 -> artifact.contentRef -> artifact.materialize.v1",
            "criteriaKeys": [
              "story-slug.lowercase-ascii",
              "story-slug.whitespace-to-hyphen",
              "story-slug.remove-punctuation",
              "story-slug.collapse-hyphens",
              "story-slug.empty-input-blocked"
            ],
            "noHandAuthoredCodeObserved": true,
            "durableProductTruthAccepted": false,
            "completionPosture": "Generated cognitive implementation proof surface materialized through resolver-mediated SEJ stages after governed provider fallback; not durable product behavior."
          }
        }
      }
    }
  ],
  "return": {
    "type": "step",
    "ref": "$steps.emitCognitiveGeneratedImplementationReceipt"
  },
  "failurePosture": "Missing provider fallback receipt, hardening receipt, red receipt, cognitive test intent, implementation projection manifest, or materialization capability blocks implementation projection.",
  "completionPosture": "This SEJ materializes a generated cognitive implementation proof surface only after primary provider failure, governed OpenAI fallback, accepted candidate hardening, and red evidence."
}
