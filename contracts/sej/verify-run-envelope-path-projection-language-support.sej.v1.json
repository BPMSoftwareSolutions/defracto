  },
  "requiredOperations": [
    {
      "operationKey": "project.value.v1",
      "purpose": "Project blocked language-support receipt.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    },
    {
      "operationKey": "evidence.emit.v1",
      "purpose": "Emit language-support receipt.",
      "requirementState": "required",
      "missingCapabilityBehavior": "blocked"
    }
  ],
  "steps": [
    {
      "id": "projectLanguageSupportReceipt",
      "type": "resolver",
      "operation": "project.value.v1",
      "payload": {
        "fields": {
          "receiptContent": {
            "schemaVersion": "defracto.sej-language-operation-support.receipt.v1",
            "receiptKey": "defracto.receipt.run-envelope-path-projection.language-support.slice-058b.v1",
            "status": "blocked",
            "blocker": "resolver_package_support_missing",
            "requiredOperation": "run.envelope.paths.project.v1",
            "approvedResolverPackage": "@bpmsoftwaresolutions/sej-resolver-node",
            "observedInstalledVersion": "0.1.8",
            "observedLatestPublishedVersion": "0.1.8",
            "nodeModulesPatchAllowed": false,
            "nodeModulesPatchApplied": false,
            "resolverEvolutionRequest": "contracts/resolver-authority/run-envelope-path-projection.resolver-evolution-request.v1.json",
            "nextBlockedSlice": "slice-058c-conveyor-owned-story-run-bootstrap",
