{
  "schemaVersion": "defracto.sej-contract.v1",
  "contractKey": "defracto.sej.verify-run-envelope-path-projection-language-support.v1",
  "contractKind": "semantic-executable-json",
  "contractStatus": "ready-for-resolver",
  "toolKey": "defracto.conveyor.language-support-verification",
  "sourceLineage": {
